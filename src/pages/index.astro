---
import config from '../content/config.json';
import works from '../content/works.json';
import '../styles/global.css';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{config.site.name}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
</head>
<body>
  <!-- 顶部导航 -->
  <header class="site-header" id="siteHeader">
    <div class="header-inner">
      <a href="/" class="logo">
        <span class="logo-icon">◆</span>
        <span class="logo-text">{config.site.name}</span>
      </a>
      <nav class="main-nav">
        <a href="/" class="nav-link active">Portfolio</a>
        <a href="/works" class="nav-link">Work</a>
        <a href="/about" class="nav-link">About</a>
      </nav>
      <a href="/about#contact" class="nav-cta">
        <span>Contact Us</span>
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17L17 7M17 7H7M17 7V17"/></svg>
      </a>
    </div>
  </header>

  <script>
    const header = document.getElementById('siteHeader');
    if (header) {
      let lastScroll = 0;
      window.addEventListener('scroll', () => {
        const currentScroll = window.scrollY;
        if (currentScroll > 80) {
          header.classList.add('scrolled');
        } else {
          header.classList.remove('scrolled');
        }
        lastScroll = currentScroll;
      });
    }
  </script>

  <!-- 视频背景加载优化脚本 -->
  <script>
    (function() {
      const heroBg = document.querySelector('.hero-bg');
      const video = document.querySelector('.hero-video') as HTMLVideoElement;
      if (!heroBg || !video) return;

      // 1. 网络检测：慢速网络不加载视频
      const conn = (navigator as any).connection;
      if (conn && (conn.saveData || conn.effectiveType === '2g' || conn.effectiveType === 'slow-2g')) {
        video.remove();
        return;
      }

      // 2. 视频可播放时淡入，隐藏回退图（降低门槛：canplay 即可，无需等 canplaythrough）
      video.addEventListener('canplay', () => {
        heroBg.classList.add('video-ready');
      });

      // 如果视频已经缓存就绑定 readyState（readyState >= 3 即 canplay）
      if (video.readyState >= 3) {
        heroBg.classList.add('video-ready');
      }

      // 3. 页面不可见时暂停视频（省电/省资源）
      document.addEventListener('visibilitychange', () => {
        if (document.hidden) {
          video.pause();
        } else {
          video.play().catch(() => {});
        }
      });

      // 4. 滚动超出 Hero 区域时暂停视频
      const hero = document.querySelector('.hero');
      if (hero) {
        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              video.play().catch(() => {});
            } else {
              video.pause();
            }
          });
        }, { threshold: 0.1 });
        observer.observe(hero);
      }
    })();
  </script>

  <!-- Hero区域 - 视频背景 -->
  <section class="hero">
    <div class="hero-bg">
      <!-- 回退静态图（视频加载前 / 移动端省流时显示） -->
      <img
        src="/images/works/2024/project-001.jpg"
        alt="Hero Background"
        class="hero-poster"
      />
      <!-- 视频背景：autoplay + muted + loop + playsinline 确保自动静音播放 -->
      <video
        class="hero-video"
        autoplay
        muted
        loop
        playsinline
        preload="auto"
        poster="/images/works/2024/project-001.jpg"
      >
        <!--
          推荐视频规格：
          ▸ 格式：MP4 (H.264 编码) — 兼容性最佳
          ▸ 备选：WebM (VP9 编码) — 更小体积、更好画质
          ▸ 分辨率：1920×1080 (16:9) — 适配主流屏幕
          ▸ 帧率：24-30fps — 背景视频无需高帧率
          ▸ 码率：2-4 Mbps — 平衡画质与文件大小
          ▸ 时长：10-30秒 — 循环播放，短即可
          ▸ 文件大小：≤ 8MB — 确保快速加载
          ▸ 音频：移除音轨 — 减少体积

          请将视频文件放入：public/videos/
          推荐命名：hero-bg.mp4 / hero-bg.webm
        -->
        <source src="/videos/bg-compressed.mp4" type="video/mp4" />
        <source src="/videos/bg.webm" type="video/webm" />
      </video>
    </div>
    <div class="hero-gradient"></div>
    <div class="hero-content">
      <div class="hero-badge">Game Interaction Designer</div>
      <h1 class="hero-title">GAME UX DESIGN</h1>
      <p class="hero-subtitle">Crafting Immersive FPS Experiences & Cross-Platform Interaction Innovation</p>
      <p class="hero-desc">A decade of dedication, from CrossFire to Counter-Strike: Future. I seamlessly blend core gameplay, narrative emotion and commercial value, using design to connect player instinct with the game world.</p>
    </div>

    <!-- Stats - Bottom Left -->
    <div class="hero-stats">
      <div class="stat-item">
        <span class="stat-number">6+</span>
        <span class="stat-label">Projects<br/>Delivered</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat-item">
        <span class="stat-number">3</span>
        <span class="stat-label">Design<br/>Categories</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat-item">
        <span class="stat-number">2024</span>
        <span class="stat-label">Latest<br/>Projects</span>
      </div>
    </div>

    <div class="hero-scroll-indicator">
      <div class="scroll-line"></div>
    </div>
  </section>

  <!-- Featured Projects Section -->
  <section class="projects-section">
    <div class="section-header">
      <span class="section-tag">Featured Work</span>
      <h2 class="section-title">GAME<br/>PROJECTS</h2>
    </div>
    
    <div class="projects-list">
      {works.works.slice(0, 5).map((work: any, index: number) => (
        <a href={`/works/${work.id}`} class="project-card">
          <div class="card-bg">
            <img src={work.cover} alt={work.title} loading="lazy">
          </div>
          <div class="card-gradient"></div>
          <div class="card-content">
            <h3 class="card-title">{work.title}</h3>
            <p class="card-desc">{work.description}</p>

          </div>
          <div class="card-meta">
            <span class="card-category">{work.category}</span>
            <span class="card-year">{work.year}</span>
          </div>
        </a>
      ))}
    </div>

    <div class="section-cta">
      <a href="/works" class="btn-view-all">
        <span>View All Projects</span>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>
  </section>

  <!-- CTA区域 -->
  <section class="cta-section">
    <div class="cta-bg"></div>
    <div class="cta-content">
      <span class="cta-tag">Get in Touch</span>
      <h2>Let's Create Something<br/>Amazing Together</h2>
      <p>Have a project in mind? I'd love to hear about it and discuss how we can bring your vision to life.</p>
      <div class="cta-actions">
        <a href="/works" class="btn-secondary">View Portfolio</a>
      </div>
    </div>
  </section>

  <!-- 页脚 -->
  <footer class="site-footer">
    <div class="footer-inner">
      <div class="footer-top">
        <div class="footer-brand">
          <div class="footer-logo">
            <span class="logo-icon">◆</span>
            <span>{config.site.name}</span>
          </div>
          <p>{config.site.description}</p>
        </div>
        <div class="footer-nav">
          <div class="footer-col">
            <h4>Navigation</h4>
            <a href="/">Home</a>
            <a href="/works">Work</a>
            <a href="/about">About</a>
          </div>
          <div class="footer-col">
            <h4>Contact</h4>
            <a href="/about#contact">Get in Touch</a>
            <a href="mailto:{config.contact.email || '#'}">Email Us</a>
          </div>
        </div>
      </div>
      <div class="footer-bottom">
        <p>&copy; 2024 {config.site.name}. All rights reserved.</p>
        <p class="footer-credit">Designed with passion</p>
      </div>
    </div>
  </footer>
</body>
</html>

<style>
  /* ===== 导航栏 ===== */
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 1000;
    padding: 1.5rem var(--container-padding);
    background: transparent;
    transition: all 0.4s var(--ease-out);
  }

  .site-header.scrolled {
    background: rgba(8, 8, 10, 0.92);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    padding-top: 0.9rem;
    padding-bottom: 0.9rem;
    border-bottom: 1px solid var(--border);
  }

  .header-inner {
    max-width: var(--container-max);
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    text-decoration: none;
    color: var(--text-primary);
  }

  .logo-icon {
    color: var(--accent);
    font-size: 0.9rem;
  }

  .logo-text {
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .main-nav {
    display: flex;
    gap: 2.5rem;
    align-items: center;
  }

  .nav-link {
    color: var(--text-secondary);
    text-decoration: none;
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    transition: color 0.3s ease;
    position: relative;
    padding: 0.25rem 0;
  }

  .nav-link.active,
  .nav-link:hover {
    color: var(--text-primary);
  }

  .nav-link::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 0;
    height: 1.5px;
    background: var(--accent);
    transition: width 0.3s var(--ease-out);
  }

  .nav-link.active::after,
  .nav-link:hover::after {
    width: 100%;
  }

  .nav-cta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: #08080a;
    text-decoration: none;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0.6rem 1.5rem;
    background: var(--accent);
    border: 1px solid var(--accent);
    border-radius: 0;
    transition: all 0.3s ease;
  }

  .nav-cta:hover {
    background: #3dd4c6;
    border-color: #3dd4c6;
    transform: translateY(-1px);
  }

  /* ===== Hero ===== */
  .hero {
    position: relative;
    width: 100%;
    height: 80vh;
    min-height: 540px;
    max-height: 800px;
    display: flex;
    align-items: flex-start;
    justify-content: flex-start;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
  }

  /* 回退图片 — 视频未加载时可见 */
  .hero-poster {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: brightness(0.35) saturate(1.1);
    z-index: 0;
  }

  /* 视频加载完成后隐藏回退图 */
  .hero-bg.video-ready .hero-poster {
    opacity: 0;
    transition: opacity 0.8s ease;
  }

  /* 视频 — 铺满容器 */
  .hero-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: brightness(0.35) saturate(1.1);
    z-index: 1;
    opacity: 0;
    transition: opacity 0.8s ease;
  }

  /* 视频加载完成后淡入 */
  .hero-bg.video-ready .hero-video {
    opacity: 1;
  }

  /* prefers-reduced-motion：尊重用户系统设置 */
  @media (prefers-reduced-motion: reduce) {
    .hero-video {
      display: none !important;
    }
    .hero-bg.video-ready .hero-poster {
      opacity: 1;
    }
  }

  .hero-gradient {
    position: absolute;
    inset: 0;
    background: 
      linear-gradient(90deg, rgba(8,8,10,0.75) 0%, rgba(8,8,10,0.5) 35%, rgba(8,8,10,0.15) 65%, transparent 100%),
      linear-gradient(180deg, rgba(8,8,10,0.5) 0%, rgba(8,8,10,0.05) 40%, rgba(8,8,10,0.6) 80%, var(--bg-primary) 100%),
      radial-gradient(ellipse at 20% 30%, rgba(78,234,219,0.06) 0%, transparent 60%);
  }

  .hero-content {
    position: relative;
    z-index: 2;
    text-align: left;
    max-width: 700px;
    padding: 0 var(--container-padding);
    margin-top: clamp(120px, 18vh, 180px);
    margin-left: clamp(2rem, 8vw, 10rem);
  }

  .hero-badge {
    display: inline-block;
    padding: 0.4rem 1.2rem;
    background: rgba(78, 234, 219, 0.12);
    border: 1px solid rgba(78, 234, 219, 0.25);
    border-radius: 0;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--accent-secondary);
    margin-bottom: 1.5rem;
  }

  .hero-title {
    font-size: clamp(2.2rem, 5vw, 3.5rem);
    font-weight: 800;
    letter-spacing: 0.02em;
    line-height: 1.15;
    word-break: keep-all;
    overflow-wrap: break-word;
    margin-bottom: 0.8rem;
    background: linear-gradient(135deg, #ffffff 0%, rgba(255,255,255,0.75) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-subtitle {
    font-size: clamp(0.9rem, 1.5vw, 1.15rem);
    color: var(--accent-secondary);
    font-weight: 500;
    letter-spacing: 0.04em;
    margin-bottom: 1.2rem;
    line-height: 1.6;
  }

  .hero-desc {
    font-size: 1rem;
    color: rgba(255, 255, 255, 0.55);
    line-height: 1.8;
    max-width: 440px;
    margin: 0 0 2.2rem 0;
  }

  /* Hero CTA 按钮 - Kevuru Games 风格 */
  .hero-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.85rem;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #08080a;
    background: var(--accent);
    border: none;
    border-radius: 0;
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .hero-cta:hover {
    background: #3dd4c6;
    transform: translateY(-2px);
    box-shadow: 0 8px 30px rgba(78, 234, 219, 0.25);
  }

  .hero-cta svg {
    transition: transform 0.3s ease;
    stroke: #08080a;
  }

  .hero-cta:hover svg {
    transform: translate(2px, -2px);
  }

  /* Hero 数据统计 - 左下角 */
  .hero-stats {
    position: absolute;
    bottom: 3.5rem;
    left: clamp(2rem, 8vw, 10rem);
    z-index: 3;
    display: flex;
    align-items: center;
    gap: 3rem;
    padding: 1.5rem 3rem;
    background: rgba(255, 255, 255, 0.04);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 16px;
  }

  .stat-item {
    display: flex;
    align-items: center;
    gap: 1rem;
    text-align: left;
  }

  .stat-number {
    font-size: 2.2rem;
    font-weight: 800;
    color: var(--text-primary);
    letter-spacing: -0.02em;
    line-height: 1;
  }

  .stat-label {
    font-size: 0.72rem;
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    line-height: 1.4;
  }

  .stat-divider {
    width: 1px;
    height: 36px;
    background: var(--border);
  }

  .hero-scroll-indicator {
    position: absolute;
    bottom: 2rem;
    right: clamp(2rem, 5vw, 5rem);
    z-index: 3;
  }

  .scroll-line {
    width: 1px;
    height: 0;
    background: rgba(255, 255, 255, 0.3);
    animation: scrollLine 2s var(--ease-in-out) infinite;
  }

  @keyframes scrollLine {
    0% { height: 0; opacity: 0; }
    50% { height: 40px; opacity: 1; }
    100% { height: 40px; opacity: 0; }
  }

  /* ===== 作品展示区 - Kevuru Games 卡片风格 ===== */
  .projects-section {
    padding: var(--section-padding) var(--container-padding);
    background: var(--bg-primary);
  }

  .section-header {
    text-align: center;
    margin-bottom: 5rem;
    max-width: 800px;
    margin-left: auto;
    margin-right: auto;
  }

  .section-tag {
    display: inline-block;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 1.2rem;
  }

  .section-title {
    font-size: clamp(2.2rem, 5vw, 3.5rem);
    font-weight: 800;
    letter-spacing: 0.02em;
    line-height: 1.15;
    color: var(--text-primary);
  }

  /* 作品列表 - 一行一个（Kevuru Games 风格） */
  .projects-list {
    max-width: 1300px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  /* === 单个作品卡片 === */
  .project-card {
    position: relative;
    display: block;
    text-decoration: none;
    color: inherit;
    border-radius: 8px;
    overflow: hidden;
    border: none;
    /* 使用 aspect-ratio 代替固定高度，保持 kevurugames.com 的 ~2.8:1 比例 */
    aspect-ratio: 2.8 / 1;
    width: 100%;
    transition: all 0.5s var(--ease-out);
  }

  .project-card:hover {
    box-shadow: 0 30px 80px -20px rgba(0, 0, 0, 0.6);
    transform: translateY(-3px);
  }

  /* 图片背景 - 铺满整个卡片 */
  .card-bg {
    position: absolute;
    inset: 0;
    z-index: 1;
  }

  .card-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    transition: transform 0.7s var(--ease-out);
  }

  .project-card:hover .card-bg img {
    transform: scale(1.04);
  }

  /* 渐变遮罩 - 左侧 + 上下边缘遮蔽 */
  .card-gradient {
    position: absolute;
    inset: 0;
    z-index: 2;
    background: 
      linear-gradient(
        90deg,
        rgba(8, 8, 12, 0.95) 0%,
        rgba(8, 8, 12, 0.88) 15%,
        rgba(8, 8, 12, 0.7) 35%,
        rgba(8, 8, 12, 0.3) 55%,
        transparent 75%
      ),
      linear-gradient(
        180deg,
        rgba(8, 8, 12, 0.4) 0%,
        transparent 15%,
        transparent 85%,
        rgba(8, 8, 12, 0.4) 100%
      );
    pointer-events: none;
  }

  /* 文字信息区 - 左上角对齐 */
  .card-content {
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    z-index: 3;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    padding: 2.5rem 3.5rem;
    max-width: 45%;
  }

  .card-title {
    font-size: clamp(1.4rem, 2.2vw, 2rem);
    font-weight: 700;
    color: #ffffff;
    margin-bottom: 0.8rem;
    letter-spacing: 0.01em;
    line-height: 1.2;
    text-transform: uppercase;
  }

  .card-desc {
    font-size: 0.88rem;
    color: rgba(255, 255, 255, 0.65);
    line-height: 1.65;
    margin-bottom: 1.8rem;
    max-width: 380px;
  }

  .card-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.75rem;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #08080a;
    background: var(--accent);
    border: none;
    border-radius: 0;
    width: fit-content;
    transition: all 0.3s ease;
  }

  .card-cta svg {
    transition: transform 0.3s ease;
    stroke: #08080a;
  }

  .project-card:hover .card-cta {
    background: #3dd4c6;
  }

  .project-card:hover .card-cta svg {
    transform: translate(2px, -2px);
  }

  /* 右下角分类信息 */
  .card-meta {
    position: absolute;
    right: 2rem;
    bottom: 1.5rem;
    z-index: 3;
    display: flex;
    gap: 1rem;
    align-items: center;
  }

  .card-category,
  .card-year {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.5);
  }

  .section-cta {
    text-align: center;
    margin-top: 4rem;
  }

  .btn-view-all {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.85rem 2.2rem;
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    color: #08080a;
    background: var(--accent);
    border: none;
    border-radius: 0;
    text-decoration: none;
    transition: all 0.3s ease;
