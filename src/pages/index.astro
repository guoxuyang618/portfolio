---
import config from '../content/config.json';
import works from '../content/works.json';
import '../styles/global.css';

// categoryTaglines: 默认文本(英文) + 对应的 i18n key
const categoryTaglines: Record<string, { text: string; i18nKey: string }> = {
  'Thematic Experience Design': { text: 'Immersive Visual Storytelling', i18nKey: 'index.tagline_thematic' },
  'Gameplay Interaction Design': { text: 'Precise Combat Interactions', i18nKey: 'index.tagline_gameplay' },
  'Monetization UX Design': { text: 'Elegant Monetization Design', i18nKey: 'index.tagline_monetization' },
  'Cross-Platform UX Design': { text: 'Seamless Multi-Device UX', i18nKey: 'index.tagline_crossplatform' },
  'System Design': { text: 'Scalable Design Systems', i18nKey: 'index.tagline_system' },
  'Creative Experience Solution': { text: 'Innovative Player Experiences', i18nKey: 'index.tagline_creative' },
};
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{config.site.name}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Inter:ital,opsz,wght@0,14..32,300;0,14..32,400;0,14..32,500;0,14..32,600;0,14..32,700;0,14..32,800&display=swap" rel="stylesheet">
</head>
<body>
  <!-- 顶部导航 -->
  <header class="site-header" id="siteHeader">
    <div class="header-inner">
      <a href="/" class="logo">
        <img src="/common/logo.webp" alt="Xuyang Logo" class="logo-img" />
      </a>
      <div class="nav-right">
        <nav class="main-nav" id="mainNav">
          <a href="/" class="nav-link active" data-i18n="nav.home">Home</a>
          <a href="/works" class="nav-link" data-i18n="nav.work">Work</a>
          <a href="/about" class="nav-link" data-i18n="nav.about">About</a>
        </nav>
        <button class="lang-toggle" id="langToggle" aria-label="Toggle language">
          <img src="/common/translate-icon.webp" alt="Language" class="lang-icon" />
          <span class="lang-label">EN</span>
        </button>
        <a href="/about#contact" class="nav-cta">
          <span data-i18n="nav.contact">Contact Me</span>
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17L17 7M17 7H7M17 7V17"/></svg>
        </a>
        <button class="hamburger" id="hamburger" aria-label="Toggle menu">
          <span class="hamburger-line"></span>
          <span class="hamburger-line"></span>
          <span class="hamburger-line"></span>
        </button>
      </div>
    </div>
  </header>

  <script>
    const header = document.getElementById('siteHeader');
    if (header) {
      let lastScroll = 0;
      window.addEventListener('scroll', () => {
        const currentScroll = window.scrollY;
        if (currentScroll > 80) {
          header.classList.add('scrolled');
        } else {
          header.classList.remove('scrolled');
        }
        lastScroll = currentScroll;
      });
    }

    const hamburger = document.getElementById('hamburger');
    const mainNav = document.getElementById('mainNav');
    if (hamburger && mainNav) {
      hamburger.addEventListener('click', () => {
        hamburger.classList.toggle('active');
        mainNav.classList.toggle('open');
      });
      mainNav.querySelectorAll('.nav-link').forEach(link => {
        link.addEventListener('click', () => {
          hamburger.classList.remove('active');
          mainNav.classList.remove('open');
        });
      });
    }
  </script>

  <!-- 视频背景加载优化脚本 -->
  <script>
    (function() {
      const heroBg = document.querySelector('.hero-bg');
      const video = document.querySelector('.hero-video') as HTMLVideoElement;
      if (!heroBg || !video) return;

      // 1. 网络检测：慢速网络不加载视频，保持深色背景
      const conn = (navigator as any).connection;
      if (conn && (conn.saveData || conn.effectiveType === '2g' || conn.effectiveType === 'slow-2g')) {
        video.remove();
        return;
      }

      // 2. 动态设置视频源（避免浏览器在解析 HTML 时提前触发加载导致闪烁）
      // WebM 优先（体积更小、画质更好），MP4 作为 fallback（兼容 iOS Safari）
      const sourceWebm = document.createElement('source');
      sourceWebm.src = 'https://xuyang-media-1416484933.cos.ap-guangzhou.myqcloud.com/portfolio%20videos/home/hero-bg.webm';
      sourceWebm.type = 'video/webm';

      const sourceMp4 = document.createElement('source');
      sourceMp4.src = 'https://xuyang-media-1416484933.cos.ap-guangzhou.myqcloud.com/portfolio%20videos/home/hero-bg.mp4';
      sourceMp4.type = 'video/mp4';

      // 3. 视频可播放时淡入
      video.addEventListener('canplay', () => {
        heroBg.classList.add('video-ready');
      }, { once: true });

      // 如果视频已缓存（readyState >= 3 即 canplay）
      if (video.readyState >= 3) {
        heroBg.classList.add('video-ready');
      }

      // 添加源并触发加载（浏览器会自动选择支持的格式）
      video.appendChild(sourceWebm);
      video.appendChild(sourceMp4);
      video.load();

      // 4. 页面不可见时暂停视频（省电/省资源）
      document.addEventListener('visibilitychange', () => {
        if (document.hidden) {
          video.pause();
        } else {
          video.play().catch(() => {});
        }
      });

      // 5. 滚动超出 Hero 区域时暂停视频
      const hero = document.querySelector('.hero');
      if (hero) {
        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              video.play().catch(() => {});
            } else {
              video.pause();
            }
          });
        }, { threshold: 0.1 });
        observer.observe(hero);
      }
    })();
  </script>



  <!-- Hero区域 - 视频背景 -->
  <section class="hero">
    <div class="hero-bg">
      <!-- 视频背景：autoplay + muted + loop + playsinline 确保自动静音播放 -->
      <video
        class="hero-video"
        autoplay
        muted
        loop
        playsinline
        webkit-playsinline
        preload="auto"
      >
        <!--
          推荐视频规格：
          ▸ 格式：MP4 (H.264 编码) — 兼容性最佳
          ▸ 备选：WebM (VP9 编码) — 更小体积、更好画质
          ▸ 分辨率：1920×1080 (16:9) — 适配主流屏幕
          ▸ 帧率：24-30fps — 背景视频无需高帧率
          ▸ 码率：2-4 Mbps — 平衡画质与文件大小
          ▸ 时长：10-30秒 — 循环播放，短即可
          ▸ 文件大小：≤ 8MB — 确保快速加载
          ▸ 音频：移除音轨 — 减少体积

          视频源通过 JS 动态注入，避免浏览器提前加载导致闪烁
        -->
      </video>
    </div>
    <div class="hero-gradient"></div>
    <div class="hero-content">
      <h1 class="hero-title" data-i18n="index.heroTitle">GAME UX DESIGN</h1>
      <p class="hero-subtitle" data-i18n="index.heroSubtitle">Crafting Immersive FPS Experiences & Cross-Platform Interaction Innovation</p>
      <p class="hero-desc" data-i18n="index.heroDesc">A decade of dedication, from CrossFire to Counter-Strike: Future. I seamlessly blend core gameplay, narrative emotion and commercial value, using design to connect player instinct with the game world.</p>
    </div>

    <!-- Stats - Bottom Left -->
    <div class="hero-stats">
      <div class="stat-item">
        <span class="stat-number">6</span>
        <span class="stat-label" data-i18n-html="index.statProjects">Project<br/>Experience</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat-item">
        <span class="stat-number">6</span>
        <span class="stat-label" data-i18n-html="index.statCategories">Design<br/>Dimensions</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat-item">
        <span class="stat-number">500+</span>
        <span class="stat-label" data-i18n-html="index.statLatest">Design Solutions<br/>Delivered</span>
      </div>
    </div>

    <div class="hero-scroll-indicator">
      <div class="scroll-line"></div>
    </div>
  </section>

  <!-- Design Abilities Section -->
  <section class="abilities-section">
    <div class="section-header reveal">
      <span class="section-tag" data-i18n="index.abilitiesTag">What I Do</span>
      <h2 class="section-title" data-i18n="index.abilitiesTitle">DESIGN ABILITIES</h2>
      <p class="section-subtitle" data-i18n="index.abilitiesSubtitle">With years of experience in game UX/UI design, I bring a comprehensive skill set spanning thematic storytelling, cross-platform adaptation, core gameplay interaction, monetization strategy, and systematic design thinking — delivering cohesive and player-centered experiences at every touchpoint.</p>
    </div>
    <div class="abilities-grid reveal-stagger">
      <div class="ability-card" data-tilt>
        <div class="ability-icon">
          <img src="/home/abilities/thematic-design.webp" alt="Thematic Experience Design" loading="lazy" />
        </div>
        <h3 class="ability-name" data-i18n="index.ability1Name">THEMATIC EXPERIENCE DESIGN</h3>
        <p class="ability-desc" data-i18n="index.ability1Desc">Making the interface an extension of the game world through stylized layouts and lore-aligned interactions.</p>
      </div>
      <div class="ability-card" data-tilt>
        <div class="ability-icon">
          <img src="/home/abilities/cross-platform.webp" alt="Cross-Platform UX Design" loading="lazy" />
        </div>
        <h3 class="ability-name" data-i18n="index.ability2Name">CROSS-PLATFORM UX DESIGN</h3>
        <p class="ability-desc" data-i18n="index.ability2Desc">Tailoring optimal interaction solutions across mobile, PC, console and XR devices.</p>
      </div>
      <div class="ability-card" data-tilt>
        <div class="ability-icon">
          <img src="/home/abilities/core-gameplay.webp" alt="Gameplay Interaction Design" loading="lazy" />
        </div>
        <h3 class="ability-name" data-i18n="index.ability3Name">GAMEPLAY INTERACTION DESIGN</h3>
        <p class="ability-desc" data-i18n="index.ability3Desc">Precise, fluid and distraction-free interaction design for combat and core mechanics.</p>
      </div>
      <div class="ability-card" data-tilt>
        <div class="ability-icon">
          <img src="/home/abilities/monetization.webp" alt="Monetization UX Design" loading="lazy" />
        </div>
        <h3 class="ability-name" data-i18n="index.ability4Name">MONETIZATION UX DESIGN</h3>
        <p class="ability-desc" data-i18n="index.ability4Desc">Seamlessly integrating monetization systems into the player journey with elegant design.</p>
      </div>
      <div class="ability-card" data-tilt>
        <div class="ability-icon">
          <img src="/home/abilities/system-design.webp" alt="System Design" loading="lazy" />
        </div>
        <h3 class="ability-name" data-i18n="index.ability5Name">SYSTEM DESIGN</h3>
        <p class="ability-desc" data-i18n="index.ability5Desc">Building scalable component libraries and design tokens for visual consistency across products.</p>
      </div>
      <div class="ability-card" data-tilt>
        <div class="ability-icon">
          <img src="/home/abilities/creative-solution.webp" alt="Creative Experience Solution" loading="lazy" />
        </div>
        <h3 class="ability-name" data-i18n="index.ability6Name">CREATIVE EXPERIENCE SOLUTION</h3>
        <p class="ability-desc" data-i18n="index.ability6Desc">Crafting innovative and memorable player experiences through creative design thinking and storytelling.</p>
      </div>
    </div>
  </section>

  <!-- Featured Projects Section -->
  <section class="projects-section">
    <div class="section-header reveal">
      <span class="section-tag" data-i18n="index.projectsTag">Featured Work</span>
      <h2 class="section-title" data-i18n="index.projectsTitle">DESIGN CATEGORIES</h2>
    </div>
    
    <div class="projects-list">
      {(() => {
        const categoryMap = new Map();
        works.works.forEach((work: any) => {
          if (!categoryMap.has(work.category)) {
            categoryMap.set(work.category, work);
          }
        });
        return Array.from(categoryMap.entries());
      })().map(([category, work]: [string, any]) => (
        <a href={`/works?category=${encodeURIComponent(category)}`} class="project-card" data-tilt data-tilt-max="6">
          <div class="card-bg">
            <img src={work.cardCover || work.cover} alt={category} loading="lazy">
          </div>
          <div class="card-gradient"></div>
          <div class="card-content">
            <h3 class="card-title" data-i18n-category={category}>{category}</h3>
            <p class="card-tagline" data-i18n={categoryTaglines[category]?.i18nKey || ''}>{categoryTaglines[category]?.text || ''}</p>
            <p class="card-desc" data-i18n-desc={work.id}>{work.description}</p>
          </div>
          <div class="card-meta">
            <span class="card-category" data-i18n-projects-count={works.works.filter((w: any) => w.category === category).length}>{works.works.filter((w: any) => w.category === category).length} Projects</span>
            <span class="card-year">{work.year}</span>
          </div>
        </a>
      ))}
    </div>

    <div class="section-cta">
      <a href="/works" class="btn-view-all">
        <span data-i18n="index.viewAll">View All Projects</span>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>
  </section>

  <!-- 游戏 Logo 跑马灯 -->
  <section class="logo-marquee-section">
    <div class="logo-marquee" id="logoMarquee">
      <div class="logo-track" id="logoTrack">
        <div class="logo-item">
          <img src="/common/game-icons/counter-storm.webp" alt="逆战：未来" />
          <div class="logo-overlay"></div>
        </div>
        <div class="logo-item">
          <img src="/common/game-icons/crossfire-mobile.webp" alt="穿越火线-枪战王者" />
          <div class="logo-overlay"></div>
        </div>
        <div class="logo-item">
          <img src="/common/game-icons/codm.webp" alt="使命召唤手游" />
          <div class="logo-overlay"></div>
        </div>
        <div class="logo-item">
          <img src="/common/game-icons/counter-storm-app.webp" alt="逆战助手" />
          <div class="logo-overlay"></div>
        </div>
        <div class="logo-item">
          <img src="/common/game-icons/pubg-mobile.webp" alt="全军出击" />
          <div class="logo-overlay"></div>
        </div>
        <div class="logo-item">
          <img src="/common/game-icons/crossfire-rainbow.webp" alt="穿越火线虹" />
          <div class="logo-overlay"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA区域 -->
  <section class="cta-section">
    <div class="cta-bg"></div>
    <div class="cta-content reveal">
      <span class="cta-tag" data-i18n="index.ctaTag">Get in Touch</span>
      <h2 data-i18n-html="index.ctaTitle">Let's Create Something<br/>Amazing Together</h2>
      <p data-i18n="index.ctaDesc">I'd love to hear about it and discuss how we can bring your vision to life.</p>
      <div class="cta-actions">
        <a href="/works" class="btn-secondary" data-i18n="index.ctaBtn">View Portfolio</a>
      </div>
    </div>
  </section>

  <!-- 页脚 -->
  <footer class="site-footer">
    <div class="footer-inner">
      <div class="footer-top">
        <div class="footer-brand">
          <div class="footer-logo">
            <img src="/common/logo.webp" alt="Xuyang Logo" class="footer-logo-img" />
          </div>
          <p data-i18n="footer.siteDesc">{config.site.description}</p>
        </div>
        <div class="footer-nav">
          <div class="footer-col">
            <h4 data-i18n="footer.navigation">Navigation</h4>
            <a href="/" data-i18n="footer.home">Home</a>
            <a href="/works" data-i18n="footer.work">Work</a>
            <a href="/about" data-i18n="footer.about">About</a>
          </div>
          <div class="footer-col">
            <h4 data-i18n="footer.contact">Contact</h4>
            <a href="/about#contact" data-i18n="footer.getInTouch">Get in Touch</a>
            <a href="mailto:{config.contact.email || '#'}" data-i18n="footer.emailMe">Email Me</a>
          </div>
        </div>
      </div>
      <div class="footer-bottom">
        <p>&copy; 2026 {config.site.name}. <span data-i18n="footer.rights">All rights reserved.</span></p>
        <p class="footer-credit" data-i18n="footer.credit">Designed with passion</p>
      </div>
    </div>
  </footer>
  <script is:inline src="/js/i18n.js"></script>

  <!-- 滚动渐入动画观察器 -->
  <script>
    (function() {
      const revealElements = document.querySelectorAll('.reveal, .reveal-stagger');
      if (!revealElements.length) return;

      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.15, rootMargin: '0px 0px -40px 0px' });

      revealElements.forEach(el => observer.observe(el));

      // Hero 入场动画
      const heroContent = document.querySelector('.hero-content');
      const heroStats = document.querySelector('.hero-stats');
      if (heroContent) {
        heroContent.style.opacity = '0';
        heroContent.style.transform = 'translateY(30px)';
        setTimeout(() => {
          heroContent.style.transition = 'opacity 1s cubic-bezier(0.16, 1, 0.3, 1), transform 1s cubic-bezier(0.16, 1, 0.3, 1)';
          heroContent.style.opacity = '1';
          heroContent.style.transform = 'translateY(0)';
        }, 300);
      }
      if (heroStats) {
        heroStats.style.opacity = '0';
        heroStats.style.transform = 'translateY(20px)';
        setTimeout(() => {
          heroStats.style.transition = 'opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1), transform 0.8s cubic-bezier(0.16, 1, 0.3, 1)';
          heroStats.style.opacity = '1';
          heroStats.style.transform = 'translateY(0)';
        }, 800);
      }

      // Project cards staggered reveal
      const cards = document.querySelectorAll('.project-card');
      const cardObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('card-visible');
            cardObserver.unobserve(entry.target);
          }
        });
      }, { threshold: 0.1, rootMargin: '0px 0px -30px 0px' });
      cards.forEach((card, i) => {
        card.style.transitionDelay = `${i * 0.12}s`;
        cardObserver.observe(card);
      });
    })();
  </script>

  <!-- 3D 透视倾斜效果 -->
  <script>
    (function() {
      const tiltCards = document.querySelectorAll('[data-tilt]');
      if (!tiltCards.length) return;

      // 是否为触屏设备（触屏不启用tilt）
      const isTouchDevice = 'ontouchstart' in window || navigator.maxTouchPoints > 0;
      if (isTouchDevice) return;

      tiltCards.forEach(card => {
        const maxTilt = parseFloat(card.getAttribute('data-tilt-max') || '12');
        const perspective = 800;
        let rafId = null;
        let currentRotateX = 0;
        let currentRotateY = 0;
        let currentTranslateY = 0;
        let currentScale = 1;
        let targetRotateX = 0;
        let targetRotateY = 0;
        let targetTranslateY = 0;
        let targetScale = 1;
        let isHovering = false;

        // 判断是能力卡片还是项目卡片
        const isAbilityCard = card.classList.contains('ability-card');
        const isProjectCard = card.classList.contains('project-card');
        // ability-card 不需要悬停动画效果
        if (isAbilityCard) return;
        const hoverScale = 1;
        const hoverLift = -8;

        function lerp(start, end, factor) {
          return start + (end - start) * factor;
        }

        function animate() {
          if (!isHovering && 
              Math.abs(currentRotateX) < 0.01 && 
              Math.abs(currentRotateY) < 0.01 &&
              Math.abs(currentTranslateY) < 0.01 &&
              Math.abs(currentScale - 1) < 0.001) {
            card.style.transform = '';
            rafId = null;
            return;
          }

          const speed = isHovering ? 0.12 : 0.08;
          currentRotateX = lerp(currentRotateX, targetRotateX, speed);
          currentRotateY = lerp(currentRotateY, targetRotateY, speed);
          currentTranslateY = lerp(currentTranslateY, targetTranslateY, speed);
          currentScale = lerp(currentScale, targetScale, speed);

          // 项目卡片需要保持 card-visible 的 translateY(0) 和 opacity
          if (isProjectCard && card.classList.contains('card-visible')) {
            card.style.transform = `perspective(${perspective}px) rotateX(${currentRotateX}deg) rotateY(${currentRotateY}deg) translateY(${currentTranslateY}px) scale(${currentScale})`;
            card.style.opacity = '1';
          } else {
            card.style.transform = `perspective(${perspective}px) rotateX(${currentRotateX}deg) rotateY(${currentRotateY}deg) translateY(${currentTranslateY}px) scale(${currentScale})`;
          }

          rafId = requestAnimationFrame(animate);
        }

        card.addEventListener('mousemove', function(e) {
          const rect = card.getBoundingClientRect();
          const x = e.clientX - rect.left;
          const y = e.clientY - rect.top;
          const centerX = rect.width / 2;
          const centerY = rect.height / 2;

          // 计算倾斜角度
          targetRotateX = -((y - centerY) / centerY) * maxTilt;
          targetRotateY = ((x - centerX) / centerX) * maxTilt;
          targetTranslateY = hoverLift;
          targetScale = hoverScale;


          if (!rafId) {
            rafId = requestAnimationFrame(animate);
          }
        });

        card.addEventListener('mouseenter', function() {
          isHovering = true;
          card.style.transition = 'box-shadow 0.15s var(--ease-out), border-color 0.15s ease, background 0.15s ease';
          if (!rafId) {
            rafId = requestAnimationFrame(animate);
          }
        });

        card.addEventListener('mouseleave', function() {
          isHovering = false;
          targetRotateX = 0;
          targetRotateY = 0;
          targetTranslateY = 0;
          targetScale = 1;
          card.style.transition = 'transform 0.3s var(--ease-out), box-shadow 0.15s var(--ease-out), border-color 0.15s ease, background 0.15s ease';
          if (!rafId) {
            rafId = requestAnimationFrame(animate);
          }
        });
      });
    })();
  </script>
</body>
</html>

<style>
  /* ===== 导航栏 ===== */
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 1000;
    padding: 1.8rem var(--container-padding);
    background: transparent;
    transition: all 0.4s var(--ease-out);
  }

  .site-header.scrolled {
    background: rgba(8, 8, 10, 0.92);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    padding-top: 0.9rem;
    padding-bottom: 0.9rem;
    border-bottom: 1px solid var(--border);
  }

  .header-inner {
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    position: relative;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    text-decoration: none;
    color: var(--text-primary);
    flex-shrink: 0;
  }

  .logo-img {
    height: 48px;
    width: auto;
    display: block;
    object-fit: contain;
  }

  .nav-right {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .main-nav {
    display: flex;
    gap: 2.5rem;
    align-items: center;
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
  }

  .nav-link {
    color: var(--text-secondary);
    text-decoration: none;
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    transition: color 0.3s ease;
    position: relative;
    padding: 0.25rem 0;
  }

  .nav-link.active,
  .nav-link:hover {
    color: var(--text-primary);
  }

  .nav-link::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 0;
    height: 1.5px;
    background: var(--accent);
    transition: width 0.3s var(--ease-out);
  }

  .nav-link.active::after,
  .nav-link:hover::after {
    width: 100%;
  }

  /* ===== 语言切换按钮 ===== */
  .lang-toggle {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    background: transparent;
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 6px;
    padding: 0.4rem 0.7rem;
    cursor: pointer;
    transition: all 0.3s ease;
    color: var(--text-secondary);
    font-family: inherit;
  }

  .lang-toggle:hover {
    border-color: var(--accent);
    color: var(--accent);
    background: rgba(45, 212, 191, 0.05);
  }

  .lang-icon {
    width: 18px;
    height: 18px;
    object-fit: contain;
    opacity: 0.85;
    transition: opacity 0.3s;
  }

  .lang-toggle:hover .lang-icon {
    opacity: 1;
  }

  .lang-label {
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .nav-cta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: #08080a;
    text-decoration: none;
    font-size: 0.78rem;
    font-family: 'Inter', sans-serif;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0.6rem 1.5rem;
    background: var(--accent);
    border: 1px solid var(--accent);
    border-radius: 0;
    transition: all 0.3s ease;
    position: relative;
    overflow: hidden;
  }

  .nav-cta::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, transparent 40%, rgba(255,255,255,0.25) 50%, transparent 60%);
    background-size: 250% 250%;
    animation: btnShine 4s ease-in-out infinite;
  }

  @keyframes btnShine {
    0%, 100% { background-position: 200% 0; }
    50% { background-position: -50% 0; }
  }

  .nav-cta:hover {
    background: #3dd4c6;
    border-color: #3dd4c6;
    transform: translateY(-1px);
    box-shadow: 0 4px 20px rgba(78, 234, 219, 0.3);
  }

  /* ===== Hero ===== */
  .hero {
    position: relative;
    width: 100%;
    height: 800px;
    display: flex;
    align-items: flex-start;
    justify-content: flex-start;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background: #08080a;
  }

  /* 视频 — 铺满容器，默认隐藏，加载完成后淡入 */
  .hero-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: brightness(0.6) saturate(1.1);
    z-index: 1;
    opacity: 0;
    transition: opacity 0.8s ease;
  }

  /* 视频加载完成后淡入 */
  .hero-bg.video-ready .hero-video {
    opacity: 1;
  }

  /* prefers-reduced-motion：尊重用户系统设置 */
  @media (prefers-reduced-motion: reduce) {
    .hero-video {
      display: none !important;
    }
  }

  .hero-gradient {
    position: absolute;
    inset: 0;
    background: 
      linear-gradient(90deg, rgba(8,8,10,0.3) 0%, rgba(8,8,10,0.15) 35%, rgba(8,8,10,0.05) 65%, transparent 100%),
      linear-gradient(180deg, rgba(8,8,10,0.2) 0%, rgba(8,8,10,0.02) 40%, rgba(8,8,10,0.25) 80%, var(--bg-primary) 100%),
      radial-gradient(ellipse at 20% 30%, rgba(78,234,219,0.06) 0%, transparent 60%);
  }

  .hero-content {
    position: relative;
    z-index: 2;
    text-align: left;
    max-width: 700px;
    padding: 0 var(--container-padding);
    margin-top: clamp(120px, 18vh, 180px);
    margin-left: clamp(2rem, 8vw, 10rem);
  }

  .hero-title {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: clamp(2.4rem, 5.5vw, 4rem);
    font-weight: 700;
    letter-spacing: 0.04em;
    line-height: 1.1;
    word-break: keep-all;
    overflow-wrap: break-word;
    margin-bottom: 0.8rem;
    background: linear-gradient(135deg, #ffffff 0%, var(--accent) 50%, rgba(255,255,255,0.75) 100%);
    background-size: 200% 200%;
    animation: shimmerTitle 6s ease-in-out infinite;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  @keyframes shimmerTitle {
    0%, 100% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
  }

  .hero-subtitle {
    font-size: clamp(0.9rem, 1.5vw, 1.15rem);
    color: var(--accent-secondary);
    font-weight: 500;
    letter-spacing: 0.04em;
    margin-bottom: 1.2rem;
    line-height: 1.6;
  }

  .hero-desc {
    font-size: 1rem;
    color: rgba(255, 255, 255, 0.55);
    line-height: 1.8;
    max-width: 440px;
    margin: 0 0 2.2rem 0;
  }

  /* Hero CTA 按钮 - Kevuru Games 风格 */
  .hero-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.85rem;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #08080a;
    background: var(--accent);
    border: none;
    border-radius: 0;
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .hero-cta:hover {
    background: #3dd4c6;
    transform: translateY(-2px);
    box-shadow: 0 8px 30px rgba(78, 234, 219, 0.25);
  }

  .hero-cta svg {
    transition: transform 0.3s ease;
    stroke: #08080a;
  }

  .hero-cta:hover svg {
    transform: translate(2px, -2px);
  }

  /* Hero 数据统计 - 左下角 */
  .hero-stats {
    position: absolute;
    bottom: 3.5rem;
    left: clamp(2rem, 8vw, 10rem);
    z-index: 3;
    display: flex;
    align-items: center;
    gap: clamp(1rem, 2.5vw, 3rem);
    padding: clamp(0.8rem, 1.3vw, 1.5rem) clamp(1.2rem, 2.5vw, 3rem);
    background: rgba(255, 255, 255, 0.04);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 16px;
    white-space: nowrap;
  }

  .stat-item {
    display: flex;
    align-items: center;
    gap: clamp(0.4rem, 0.8vw, 1rem);
    text-align: left;
  }

  .stat-number {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: clamp(1.4rem, 2vw, 2.4rem);
    font-weight: 700;
    color: var(--accent);
    letter-spacing: -0.01em;
    line-height: 1;
  }

  .stat-label {
    font-size: clamp(0.5rem, 0.6vw, 0.72rem);
    font-family: 'Inter', sans-serif;
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    line-height: 1.4;
  }

  .stat-divider {
    width: 1px;
    height: clamp(20px, 3vw, 36px);
    background: var(--border);
  }

  .hero-scroll-indicator {
    position: absolute;
    bottom: 2rem;
    right: clamp(2rem, 5vw, 5rem);
    z-index: 3;
  }

  .scroll-line {
    width: 1px;
    height: 0;
    background: rgba(255, 255, 255, 0.3);
    animation: scrollLine 2s var(--ease-in-out) infinite;
  }

  @keyframes scrollLine {
    0% { height: 0; opacity: 0; }
    50% { height: 40px; opacity: 1; }
    100% { height: 40px; opacity: 0; }
  }

  /* ===== 设计能力分类区域 ===== */
  .abilities-section {
    padding: 5rem var(--container-padding) 2rem;
    background: var(--bg-primary);
    position: relative;
  }

  /* 微妙的网格纹理背景 */
  .abilities-section::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: 
      linear-gradient(rgba(78, 234, 219, 0.02) 1px, transparent 1px),
      linear-gradient(90deg, rgba(78, 234, 219, 0.02) 1px, transparent 1px);
    background-size: 60px 60px;
    mask-image: radial-gradient(ellipse at 50% 30%, black 0%, transparent 70%);
    -webkit-mask-image: radial-gradient(ellipse at 50% 30%, black 0%, transparent 70%);
    pointer-events: none;
  }

  .abilities-grid {
    max-width: 1400px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 1.5rem;
    justify-items: center;
  }

  .ability-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 1.8rem 1rem 1.6rem;
    border-radius: 0;
    border: 1px solid var(--border);
    background: linear-gradient(180deg, rgba(78, 234, 219, 0.04) 0%, rgba(8, 8, 10, 0.6) 100%);
    transition: background 0.15s ease, border-color 0.15s ease;
    position: relative;
    overflow: hidden;
    width: 100%;
    transform-style: flat;
    will-change: auto;
  }


  .ability-card:hover {
    border-color: rgba(255, 255, 255, 0.3);
    background: #ffffff;
    box-shadow: none;
  }

  .ability-icon {
    width: 64px;
    height: 64px;
    margin-bottom: 1.2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    z-index: 1;
  }

  .ability-icon img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    filter: brightness(0) invert(1) opacity(0.85);
    transition: filter 0.15s ease, transform 0.15s var(--ease-out);
  }

  .ability-card:hover .ability-icon img {
    filter: brightness(0) invert(0) opacity(0.85);
    transform: none;
  }

  .ability-name {
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #ffffff;
    margin-bottom: 0.75rem;
    position: relative;
    z-index: 1;
    word-break: break-word;
    transition: color 0.15s ease;
  }

  .ability-card:hover .ability-name {
    color: #1a1a2e;
  }

  .ability-desc {
    font-size: 0.82rem;
    color: var(--text-secondary);
    line-height: 1.6;
    position: relative;
    z-index: 1;
    margin: 0;
    transition: color 0.15s ease;
  }

  .ability-card:hover .ability-desc {
    color: #3a3a5c;
  }

  /* ===== 作品展示区 - Kevuru Games 卡片风格 ===== */
  .projects-section {
    padding: 3rem var(--container-padding) var(--section-padding);
    background: var(--bg-primary);
  }

  .section-header {
    text-align: center;
    margin-bottom: 1.75rem;
    max-width: 800px;
    margin-left: auto;
    margin-right: auto;
  }

  .section-tag {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.72rem;
    font-family: 'Inter', sans-serif;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 1.2rem;
  }

  .section-tag::before,
  .section-tag::after {
    content: '';
    width: 24px;
    height: 1px;
    background: var(--accent);
    opacity: 0.4;
  }

  .section-title {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    font-weight: 700;
    letter-spacing: 0.06em;
    line-height: 1.15;
    color: var(--text-primary);
  }

  .section-subtitle {
    font-size: 0.95rem;
    color: var(--text-secondary);
    line-height: 1.75;
    margin-top: 1.5rem;
    max-width: 680px;
    margin-left: auto;
    margin-right: auto;
  }

  /* 作品列表 - 一行一个（Kevuru Games 风格） */
  .projects-list {
    max-width: 1300px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  /* === 单个作品卡片 === */
  .project-card {
    position: relative;
    display: block;
    text-decoration: none;
    color: inherit;
    border-radius: 0;
    overflow: hidden;
    border: 1px solid transparent;
    /* 使用 aspect-ratio 代替固定高度 */
    aspect-ratio: 2.8 / 1;
    width: 100%;
    transition: box-shadow 0.15s var(--ease-out), border-color 0.15s var(--ease-out);
    /* 渐入动画初始状态 */
    opacity: 0;
    transform: translateY(40px);
    /* 3D 透视 */
    transform-style: preserve-3d;
    will-change: transform;
  }


  .project-card.card-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .project-card:hover {
    box-shadow: 
      0 30px 80px -15px rgba(0, 0, 0, 0.7),
      0 0 60px -5px rgba(78, 234, 219, 0.15),
      0 0 0 1px rgba(78, 234, 219, 0.2);
    border: 1px solid rgba(78, 234, 219, 0.15);
    border-left: 4px solid var(--accent);
  }

  .project-card:hover .card-title {
    color: var(--accent);
    text-shadow: 0 0 40px rgba(78, 234, 219, 0.5);
    transform: translateX(4px);
  }

  /* 图片背景 - 铺满整个卡片 */
  .card-bg {
    position: absolute;
    inset: 0;
    z-index: 1;
  }

  .card-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    transition: transform 0.2s var(--ease-out), filter 0.2s var(--ease-out);
  }

  .project-card:hover .card-bg img {
    transform: scale(1.08);
    filter: brightness(1.1);
  }

  /* 渐变遮罩 - 左侧 + 上下边缘遮蔽 */
  .card-gradient {
    position: absolute;
    inset: 0;
    z-index: 2;
    background: 
      linear-gradient(
        90deg,
        rgba(8, 8, 12, 0.4) 0%,
        rgba(8, 8, 12, 0.28) 15%,
        rgba(8, 8, 12, 0.15) 35%,
        rgba(8, 8, 12, 0.05) 55%,
        transparent 75%
      ),
      linear-gradient(
        180deg,
        rgba(8, 8, 12, 0.12) 0%,
        transparent 15%,
        transparent 85%,
        rgba(8, 8, 12, 0.12) 100%
      );
    pointer-events: none;
  }

  /* 文字信息区 - 左上角对齐 */
  .card-content {
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    z-index: 3;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    padding: 1.5rem 3.5rem;
    max-width: 45%;
  }

  .card-title {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: clamp(1.4rem, 2.2vw, 2rem);
    font-weight: 700;
    color: #ffffff;
    margin-bottom: 0.8rem;
    letter-spacing: 0.01em;
    line-height: 1.2;
    text-transform: uppercase;
    transition: color 0.15s ease, text-shadow 0.15s ease, transform 0.15s var(--ease-out);
  }

  /* 英文模式下卡片标题字号稍小 */
  :global(html[lang="en"]) .card-title {
    font-size: clamp(1.15rem, 1.8vw, 1.65rem);
  }

  .card-tagline {
    font-size: 0.78rem;
    color: rgba(255, 255, 255, 0.45);
    font-weight: 400;
    letter-spacing: 0.06em;
    line-height: 1.4;
    margin: 0;
  }

  .card-desc {
    font-size: 0.88rem;
    color: rgba(255, 255, 255, 0.65);
    line-height: 1.65;
    margin-bottom: 1.8rem;
    max-width: 380px;
  }

  .card-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.75rem;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #08080a;
    background: var(--accent);
    border: none;
    border-radius: 0;
    width: fit-content;
    transition: all 0.15s var(--ease-out);
  }

  .card-cta svg {
    transition: transform 0.3s ease;
    stroke: #08080a;
  }

  .project-card:hover .card-cta {
    background: #3dd4c6;
    box-shadow: 0 4px 20px rgba(78, 234, 219, 0.4);
    transform: translateX(4px);
  }

  .project-card:hover .card-cta svg {
    transform: translate(5px, -3px);
  }

  /* 右下角分类信息 */
  .card-meta {
    position: absolute;
    right: 2rem;
    bottom: 1.5rem;
    z-index: 3;
    display: flex;
    gap: 1rem;
    align-items: center;
  }

  .card-category,
  .card-year {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.5);
  }

  .section-cta {
    text-align: center;
    margin-top: 4rem;
  }

  .btn-view-all {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    width: 240px;
    padding: 0.85rem 0;
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    color: #08080a;
    background: var(--accent);
    border: none;
    border-radius: 0;
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .btn-view-all:hover {
    background: #3dd4c6;
    transform: translateY(-2px);
  }

  /* ===== 游戏 Logo 展示栏 ===== */
  .logo-marquee-section {
    padding: 2.5rem 0;
    background: var(--bg-primary);
    position: relative;
  }

  .logo-marquee-section::before {
    content: '';
    position: absolute;
    top: 0;
    left: 10%;
    right: 10%;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--border-hover), transparent);
  }

  .logo-marquee-section::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 10%;
    right: 10%;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--border-hover), transparent);
  }

  .logo-marquee {
    position: relative;
    width: 100%;
    padding: 12px 0;
    display: flex;
    justify-content: center;
  }

  .logo-track {
    display: flex;
    gap: 4rem;
    justify-content: center;
    align-items: center;
  }

  .logo-item {
    position: relative;
    flex-shrink: 0;
    width: 60px;
    height: 60px;
    border-radius: 0;
    overflow: hidden;
    border: 1px solid transparent;
    transition: transform 0.35s var(--ease-out), box-shadow 0.35s var(--ease-out), border-color 0.35s ease;
    cursor: pointer;
  }

  .logo-item:hover {
    transform: scale(1.1);
    border-color: transparent;
    box-shadow: none;
  }

  .logo-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    border-radius: 0;
    transition: filter 0.35s ease;
  }

  .logo-item:hover img {
    filter: brightness(1.2) saturate(1.15);
  }

  .logo-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border-radius: 0;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.6) 0%, rgba(0, 0, 0, 0.15) 50%, transparent 100%);
    pointer-events: none;
    transition: opacity 0.35s ease;
  }

  .logo-item:hover .logo-overlay {
    opacity: 0;
  }

  /* ===== CTA 区域 ===== */
  .cta-section {
    position: relative;
    padding: var(--section-padding) var(--container-padding);
    text-align: center;
    overflow: hidden;
  }

  .cta-bg {
    position: absolute;
    inset: 0;
    background: 
      radial-gradient(ellipse at 50% 0%, rgba(78, 234, 219, 0.18) 0%, transparent 50%),
      radial-gradient(ellipse at 20% 80%, rgba(78, 234, 219, 0.06) 0%, transparent 40%),
      radial-gradient(ellipse at 80% 60%, rgba(78, 234, 219, 0.04) 0%, transparent 40%),
      var(--bg-secondary);
    animation: ctaPulse 8s ease-in-out infinite;
  }

  /* CTA 顶部分隔线光效 */
  .cta-section::before {
    content: '';
    position: absolute;
    top: 0;
    left: 10%;
