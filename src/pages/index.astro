---
import config from '../content/config.json';
import works from '../content/works.json';
import '../styles/global.css';
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{config.site.name}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
</head>
<body>
  <!-- 顶部导航 -->
  <header class="site-header" id="siteHeader">
    <div class="header-inner">
      <a href="/" class="logo">
        <span class="logo-icon">◆</span>
        <span class="logo-text">{config.site.name}</span>
      </a>
      <nav class="main-nav">
        <a href="/" class="nav-link active">Portfolio</a>
        <a href="/works" class="nav-link">Work</a>
        <a href="/about" class="nav-link">About</a>
      </nav>
      <a href="/about#contact" class="nav-cta">
        <span>Contact Us</span>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17L17 7M17 7H7M17 7V17"/></svg>
      </a>
    </div>
  </header>

  <script>
    const header = document.getElementById('siteHeader');
    let lastScroll = 0;
    window.addEventListener('scroll', () => {
      const currentScroll = window.scrollY;
      if (currentScroll > 80) {
        header.classList.add('scrolled');
      } else {
        header.classList.remove('scrolled');
      }
      lastScroll = currentScroll;
    });
  </script>

  <!-- Hero区域 - Kevuru Games 风格 -->
  <section class="hero">
    <div class="hero-bg">
      <img src="/images/works/2024/project-001.jpg" alt="Hero Background">
    </div>
    <div class="hero-gradient"></div>
    <div class="hero-content">
      <div class="hero-badge">GAME DESIGN PORTFOLIO</div>
      <h1 class="hero-title">OUR<br/>PORTFOLIO</h1>
      <p class="hero-desc">Showcasing innovative game design solutions<br/>and creative visual experiences</p>
    </div>

    <!-- 数据统计 - Kevuru Games 风格 -->
    <div class="hero-stats">
      <div class="stat-item">
        <span class="stat-number">6+</span>
        <span class="stat-label">Projects<br/>Delivered</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat-item">
        <span class="stat-number">3</span>
        <span class="stat-label">Design<br/>Categories</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat-item">
        <span class="stat-number">2024</span>
        <span class="stat-label">Latest<br/>Projects</span>
      </div>
    </div>

    <div class="hero-scroll-indicator">
      <div class="scroll-line"></div>
    </div>
  </section>

  <!-- 精选作品区域 - Kevuru Games 首页卡片风格 -->
  <section class="projects-section">
    <div class="section-header">
      <span class="section-tag">Featured Work</span>
      <h2 class="section-title">OUR TOP-RATED<br/>PROJECTS</h2>
    </div>
    
    <div class="projects-list">
      {works.works.slice(0, 6).map((work: any, index: number) => (
        <a href={`/works/${work.id}`} class="project-card">
          <div class="card-bg">
            <img src={work.cover} alt={work.title} loading="lazy">
          </div>
          <div class="card-gradient"></div>
          <div class="card-content">
            <h3 class="card-title">{work.title}</h3>
            <p class="card-desc">{work.description}</p>
            <span class="card-cta">
              SEE MORE
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M7 17L17 7M17 7H7M17 7V17"/></svg>
            </span>
          </div>
          <div class="card-meta">
            <span class="card-category">{work.category}</span>
            <span class="card-year">{work.year}</span>
          </div>
        </a>
      ))}
    </div>

    <div class="section-cta">
      <a href="/works" class="btn-view-all">
        <span>View All Projects</span>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>
  </section>

  <!-- CTA区域 -->
  <section class="cta-section">
    <div class="cta-bg"></div>
    <div class="cta-content">
      <span class="cta-tag">Get in Touch</span>
      <h2>Let's Create Something<br/>Amazing Together</h2>
      <p>Have a project in mind? We'd love to hear about it and discuss how we can bring your vision to life.</p>
      <div class="cta-actions">
        <a href="/about#contact" class="btn-primary">
          <span>Start a Project</span>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17L17 7M17 7H7M17 7V17"/></svg>
        </a>
        <a href="/works" class="btn-secondary">View Portfolio</a>
      </div>
    </div>
  </section>

  <!-- 页脚 -->
  <footer class="site-footer">
    <div class="footer-inner">
      <div class="footer-top">
        <div class="footer-brand">
          <div class="footer-logo">
            <span class="logo-icon">◆</span>
            <span>{config.site.name}</span>
          </div>
          <p>{config.site.description}</p>
        </div>
        <div class="footer-nav">
          <div class="footer-col">
            <h4>Navigation</h4>
            <a href="/">Home</a>
            <a href="/works">Work</a>
            <a href="/about">About</a>
          </div>
          <div class="footer-col">
            <h4>Contact</h4>
            <a href="/about#contact">Get in Touch</a>
            <a href="mailto:{config.contact.email || '#'}">Email Us</a>
          </div>
        </div>
      </div>
      <div class="footer-bottom">
        <p>&copy; 2024 {config.site.name}. All rights reserved.</p>
        <p class="footer-credit">Designed with passion</p>
      </div>
    </div>
  </footer>
</body>
</html>

<style>
  /* ===== 导航栏 ===== */
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 1000;
    padding: 1.5rem var(--container-padding);
    background: transparent;
    transition: all 0.4s var(--ease-out);
  }

  .site-header.scrolled {
    background: rgba(8, 8, 10, 0.92);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    padding-top: 0.9rem;
    padding-bottom: 0.9rem;
    border-bottom: 1px solid var(--border);
  }

  .header-inner {
    max-width: var(--container-max);
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    text-decoration: none;
    color: var(--text-primary);
  }

  .logo-icon {
    color: var(--accent);
    font-size: 0.9rem;
  }

  .logo-text {
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .main-nav {
    display: flex;
    gap: 2.5rem;
    align-items: center;
  }

  .nav-link {
    color: var(--text-secondary);
    text-decoration: none;
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    transition: color 0.3s ease;
    position: relative;
    padding: 0.25rem 0;
  }

  .nav-link.active,
  .nav-link:hover {
    color: var(--text-primary);
  }

  .nav-link::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 0;
    height: 1.5px;
    background: var(--accent);
    transition: width 0.3s var(--ease-out);
  }

  .nav-link.active::after,
  .nav-link:hover::after {
    width: 100%;
  }

  .nav-cta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: #08080a;
    text-decoration: none;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    padding: 0.6rem 1.4rem;
    background: var(--accent);
    border: 1px solid var(--accent);
    border-radius: 0;
    transition: all 0.3s ease;
  }

  .nav-cta:hover {
    background: #3dd4c6;
    border-color: #3dd4c6;
    transform: translateY(-1px);
  }

  /* ===== Hero ===== */
  .hero {
    position: relative;
    width: 100%;
    height: 100vh;
    min-height: 700px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
  }

  .hero-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: brightness(0.35) saturate(1.1);
  }

  .hero-gradient {
    position: absolute;
    inset: 0;
    background: 
      linear-gradient(180deg, rgba(8,8,10,0.4) 0%, rgba(8,8,10,0.1) 40%, rgba(8,8,10,0.7) 80%, var(--bg-primary) 100%),
      radial-gradient(ellipse at 30% 50%, rgba(78,234,219,0.08) 0%, transparent 60%);
  }

  .hero-content {
    position: relative;
    z-index: 2;
    text-align: center;
    max-width: 900px;
    padding: 0 2rem;
  }

  .hero-badge {
    display: inline-block;
    padding: 0.4rem 1.2rem;
    background: rgba(78, 234, 219, 0.12);
    border: 1px solid rgba(78, 234, 219, 0.25);
    border-radius: 0;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--accent-secondary);
    margin-bottom: 2rem;
  }

  .hero-title {
    font-size: clamp(3.5rem, 8vw, 7rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.0;
    margin-bottom: 1.5rem;
    background: linear-gradient(135deg, #ffffff 0%, rgba(255,255,255,0.7) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-desc {
    font-size: 1.1rem;
    color: rgba(255, 255, 255, 0.5);
    line-height: 1.7;
    max-width: 500px;
    margin: 0 auto;
  }

  /* Hero 数据统计 */
  .hero-stats {
    position: absolute;
    bottom: 5rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 3;
    display: flex;
    align-items: center;
    gap: 3rem;
    padding: 1.5rem 3rem;
    background: rgba(255, 255, 255, 0.04);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 16px;
  }

  .stat-item {
    display: flex;
    align-items: center;
    gap: 1rem;
    text-align: left;
  }

  .stat-number {
    font-size: 2.2rem;
    font-weight: 800;
    color: var(--text-primary);
    letter-spacing: -0.02em;
    line-height: 1;
  }

  .stat-label {
    font-size: 0.72rem;
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    line-height: 1.4;
  }

  .stat-divider {
    width: 1px;
    height: 36px;
    background: var(--border);
  }

  .hero-scroll-indicator {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 3;
  }

  .scroll-line {
    width: 1px;
    height: 0;
    background: rgba(255, 255, 255, 0.3);
    animation: scrollLine 2s var(--ease-in-out) infinite;
  }

  @keyframes scrollLine {
    0% { height: 0; opacity: 0; }
    50% { height: 40px; opacity: 1; }
    100% { height: 40px; opacity: 0; }
  }

  /* ===== 作品展示区 - Kevuru Games 卡片风格 ===== */
  .projects-section {
    padding: var(--section-padding) var(--container-padding);
    background: var(--bg-primary);
  }

  .section-header {
    text-align: center;
    margin-bottom: 5rem;
    max-width: 800px;
    margin-left: auto;
    margin-right: auto;
  }

  .section-tag {
    display: inline-block;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 1.2rem;
  }

  .section-title {
    font-size: clamp(2.2rem, 5vw, 3.5rem);
    font-weight: 800;
    letter-spacing: 0.02em;
    line-height: 1.15;
    color: var(--text-primary);
  }

  /* 作品列表 - 一行一个 */
  .projects-list {
    max-width: var(--container-max);
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  /* === 单个作品卡片 - 图片全背景 + 左侧渐变叠加文字 === */
  .project-card {
    position: relative;
    display: block;
    text-decoration: none;
    color: inherit;
    border-radius: 16px;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.08);
    height: 420px;
    transition: all 0.5s var(--ease-out);
  }

  .project-card:hover {
    border-color: rgba(255, 255, 255, 0.15);
    box-shadow: 0 30px 80px -20px rgba(0, 0, 0, 0.6);
    transform: translateY(-3px);
  }

  /* 图片背景 - 铺满整个卡片 */
  .card-bg {
    position: absolute;
    inset: 0;
    z-index: 1;
  }

  .card-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    transition: transform 0.7s var(--ease-out);
  }

  .project-card:hover .card-bg img {
    transform: scale(1.04);
  }

  /* 左侧渐变遮罩 - 从深色到透明 */
  .card-gradient {
    position: absolute;
    inset: 0;
    z-index: 2;
    background: linear-gradient(
      90deg,
      rgba(8, 8, 12, 0.95) 0%,
      rgba(8, 8, 12, 0.88) 15%,
      rgba(8, 8, 12, 0.7) 35%,
      rgba(8, 8, 12, 0.3) 55%,
      transparent 75%
    );
    pointer-events: none;
  }

  /* 文字信息区 - 叠加在渐变上 */
  .card-content {
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    z-index: 3;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 3rem 3.5rem;
    max-width: 50%;
  }

  .card-title {
    font-size: clamp(1.5rem, 2.5vw, 2rem);
    font-weight: 800;
    color: #ffffff;
    margin-bottom: 1rem;
    letter-spacing: -0.01em;
    line-height: 1.2;
    text-transform: uppercase;
  }

  .card-desc {
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.7);
    line-height: 1.7;
    margin-bottom: 2rem;
    max-width: 420px;
  }

  .card-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.65rem 1.6rem;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #08080a;
    background: var(--accent);
    border: none;
    border-radius: 0;
    width: fit-content;
    transition: all 0.3s ease;
  }

  .card-cta svg {
    transition: transform 0.3s ease;
    stroke: #08080a;
  }

  .project-card:hover .card-cta {
    background: #3dd4c6;
  }

  .project-card:hover .card-cta svg {
    transform: translate(2px, -2px);
  }

  /* 右下角分类信息 */
  .card-meta {
    position: absolute;
    right: 2rem;
    bottom: 1.5rem;
    z-index: 3;
    display: flex;
    gap: 1rem;
    align-items: center;
  }

  .card-category,
  .card-year {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.5);
  }

  .section-cta {
    text-align: center;
    margin-top: 4rem;
  }

  .btn-view-all {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 1rem 2.2rem;
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    color: #08080a;
    background: var(--accent);
    border: none;
    border-radius: 0;
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .btn-view-all:hover {
    background: #3dd4c6;
    transform: translateY(-2px);
  }

  /* ===== CTA 区域 ===== */
  .cta-section {
    position: relative;
    padding: var(--section-padding) var(--container-padding);
    text-align: center;
    overflow: hidden;
  }

  .cta-bg {
    position: absolute;
    inset: 0;
    background: 
      radial-gradient(ellipse at 50% 0%, var(--accent-glow) 0%, transparent 60%),
      var(--bg-secondary);
  }

  .cta-content {
    position: relative;
    z-index: 2;
    max-width: 600px;
    margin: 0 auto;
  }

  .cta-tag {
    display: inline-block;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 1.5rem;
  }

  .cta-content h2 {
    font-size: clamp(2rem, 4vw, 2.8rem);
    font-weight: 700;
    margin-bottom: 1rem;
    line-height: 1.2;
    color: var(--text-primary);
  }

  .cta-content p {
    font-size: 1rem;
    color: var(--text-secondary);
    margin-bottom: 2.5rem;
    line-height: 1.7;
  }

  .cta-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    align-items: center;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.85rem 1.8rem;
    background: var(--accent);
    color: #08080a;
    text-decoration: none;
    border-radius: 0;
    font-weight: 600;
    font-size: 0.85rem;
    letter-spacing: 0.03em;
    transition: all 0.3s ease;
  }

  .btn-primary:hover {
    background: #3dd4c6;
    transform: translateY(-2px);
  }

  .btn-secondary {
    display: inline-flex;
    align-items: center;
    padding: 0.85rem 1.8rem;
    color: var(--text-primary);
    text-decoration: none;
    background: var(--bg-tertiary);
    border: none;
    border-radius: 0;
    font-weight: 600;
    font-size: 0.85rem;
    transition: all 0.3s ease;
  }

  .btn-secondary:hover {
    background: #2a2a30;
  }

  /* ===== 页脚 ===== */
  .site-footer {
    padding: 4rem var(--container-padding) 2rem;
    background: var(--bg-primary);
    border-top: 1px solid var(--border);
  }

  .footer-inner {
    max-width: var(--container-max);
    margin: 0 auto;
  }

  .footer-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    padding-bottom: 3rem;
    border-bottom: 1px solid var(--border);
    margin-bottom: 2rem;
  }

  .footer-logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-primary);
    margin-bottom: 0.75rem;
  }

  .footer-brand p {
    color: var(--text-tertiary);
    font-size: 0.9rem;
    max-width: 280px;
    line-height: 1.6;
  }

  .footer-nav {
    display: flex;
    gap: 5rem;
  }

  .footer-col h4 {
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-secondary);
    margin-bottom: 1rem;
  }

  .footer-col a {
    display: block;
    color: var(--text-tertiary);
    text-decoration: none;
    font-size: 0.9rem;
    padding: 0.3rem 0;
    transition: color 0.2s;
  }

  .footer-col a:hover {
    color: var(--text-primary);
  }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .footer-bottom p {
    color: var(--text-tertiary);
    font-size: 0.8rem;
  }

  .footer-credit {
    font-size: 0.75rem;
    color: var(--text-tertiary);
  }

  /* ===== 响应式 ===== */
  @media (max-width: 1024px) {
    .project-card {
      height: 360px;
    }

    .card-content {
      padding: 2.5rem 2.5rem;
      max-width: 55%;
    }

    .card-title {
      font-size: 1.5rem;
    }

    .card-desc {
      font-size: 0.85rem;
    }

    .hero-stats {
      gap: 2rem;
      padding: 1.2rem 2rem;
    }
    .stat-number {
      font-size: 1.6rem;
    }
  }

  @media (max-width: 768px) {
    .site-header {
      padding: 1rem 1.5rem;
    }

    .site-header.scrolled {
      padding-top: 0.7rem;
      padding-bottom: 0.7rem;
    }

    .logo-text {
      font-size: 0.72rem;
    }

    .main-nav {
      gap: 1.2rem;
    }

    .nav-link {
      font-size: 0.7rem;
    }

    .nav-cta {
      font-size: 0.7rem;
      padding: 0.45rem 1rem;
    }

    .nav-cta svg {
      display: none;
    }

    .hero-title {
      font-size: 3rem;
    }

    .hero-desc {
      font-size: 0.95rem;
    }

