---
import worksData from '../../content/works.json';

export function getStaticPaths() {
  return worksData.works.map((work: any) => ({
    params: { id: work.id },
    props: { work }
  }));
}

const { work } = Astro.props;
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{work?.title || '作品详情'} - 设计师作品集</title>
  <link rel="stylesheet" href="/src/styles/global.css">
</head>
<body>
  <!-- 作品主图 -->
  <section class="work-hero">
    <img src={work?.cover} alt={work?.title} />
    <div class="hero-overlay"></div>
  </section>

  <!-- 顶部导航 -->
  <header class="site-header">
    <div class="header-inner">
      <a href="/" class="logo">Portfolio</a>
      <nav class="main-nav">
        <a href="/">Home</a>
        <a href="/works">Work</a>
        <a href="/about">About</a>
      </nav>
    </div>
  </header>

  <main class="work-detail">
    <div class="container">
      <!-- 作品标题和基本信息 -->
      <div class="work-header">
        <h1>{work?.title}</h1>
        <div class="work-meta">
          <span class="meta-item">{work?.category}</span>
          <span class="meta-divider">·</span>
          <span class="meta-item">{work?.year}</span>
        </div>
      </div>

      <!-- 作品描述 -->
      <section class="work-section">
        <h2>项目介绍</h2>
        <p class="work-description">
          {work?.description || '暂无描述'}
        </p>
      </section>

      <!-- 作品图片展示 -->
      <section class="work-section">
        <h2>作品展示</h2>
        <div class="work-gallery">
          <img src={work?.cover} alt={work?.title} class="gallery-main" />
        </div>
      </section>

      <!-- 左图右文 -->
      <section class="work-section">
        <div class="alternating-layout">
          <div class="alternating-image">
            <img src="/images/works/2024/project-001.jpg" alt="Detail 1">
          </div>
          <div class="alternating-text">
            <h3>设计思路</h3>
            <p>详细描述该作品的设计思路、用户调研、交互流程等信息。展示设计背后的思考过程和解决方案。</p>
          </div>
        </div>
      </section>

      <!-- 右图左文 -->
      <section class="work-section">
        <div class="alternating-layout reverse">
          <div class="alternating-image">
            <img src="/images/works/2024/project-001.jpg" alt="Detail 2">
          </div>
          <div class="alternating-text">
            <h3>视觉效果</h3>
            <p>详细描述该作品的视觉设计、色彩运用、排版布局等细节。展示最终的设计成果和视觉表现。</p>
          </div>
        </div>
      </section>

      <!-- 左图右文 -->
      <section class="work-section">
        <div class="alternating-layout">
          <div class="alternating-image">
            <img src="/images/works/2024/project-001.jpg" alt="Detail 3">
          </div>
          <div class="alternating-text">
            <h3>交互体验</h3>
            <p>详细描述该作品的交互设计、用户流程、动效表现等。展示如何通过交互设计提升用户体验。</p>
          </div>
        </div>
      </section>

      <!-- 右图左文 -->
      <section class="work-section">
        <div class="alternating-layout reverse">
          <div class="alternating-image">
            <img src="/images/works/2024/project-001.jpg" alt="Detail 4">
          </div>
          <div class="alternating-text">
            <h3>项目总结</h3>
            <p>总结该项目的成果、收获和反思。分享在项目中遇到的挑战以及最终的解决方案。</p>
          </div>
        </div>
      </section>

      <!-- 视频展示（如果有） -->
      {work?.video && (
        <section class="work-section">
          <h2>演示视频</h2>
          <div class="work-video">
            <iframe
              src={`https://player.bilibili.com/player.html?bvid=${work.video.id}&page=1`}
              scrolling="no"
              frameborder="no"
              allowfullscreen="true">
            </iframe>
          </div>
        </section>
      )}

      <!-- 导航 -->
      <div class="work-nav">
        <a href="/works" class="btn-back">← 返回作品列表</a>
      </div>
    </div>
  </main>

  <!-- 页脚 -->
  <footer class="site-footer">
    <div class="footer-inner">
      <div class="footer-brand">
        <h3>Portfolio</h3>
        <p>Creative Design Solutions</p>
      </div>
      <div class="footer-links">
        <a href="/">Home</a>
        <a href="/works">Work</a>
        <a href="/about">About</a>
      </div>
      <div class="footer-copyright">
        <p>&copy; 2024. All rights reserved.</p>
      </div>
    </div>
  </footer>
</body>
</html>

<style>
  /* 作品主图 */
  .work-hero {
    width: 100%;
    height: 60vh;
    position: relative;
    overflow: hidden;
  }

  .work-hero img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 50%;
    background: linear-gradient(to top, var(--bg-primary), transparent);
  }

  /* 顶部导航 - 参考kevurugames.com */
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 100;
    padding: 1.25rem 3rem;
    background: rgba(10, 10, 10, 0.95);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }

  .header-inner {
    max-width: 1400px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .site-header .logo {
    font-size: 1.1rem;
    font-weight: 700;
    color: white;
    text-decoration: none;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .main-nav {
    display: flex;
    gap: 2.5rem;
  }

  .main-nav a {
    color: rgba(255,255,255,0.65);
    text-decoration: none;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    transition: color 0.25s ease;
    position: relative;
  }

  .main-nav a::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 0;
    height: 1px;
    background: white;
    transition: width 0.25s ease;
  }

  .main-nav a:hover {
    color: white;
  }

  .main-nav a:hover::after {
    width: 100%;
  }

  /* 作品详情 */
  .work-detail {
    background: var(--bg-primary);
    padding: 2rem 0 4rem;
  }

  .work-header {
    margin-top: -10rem;
    position: relative;
    z-index: 1;
    margin-bottom: 3rem;
  }

  .work-header h1 {
    font-size: 3rem;
    margin-bottom: 1rem;
  }

  .work-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--text-secondary);
    font-size: 1.1rem;
  }

  .meta-divider {
    opacity: 0.5;
  }

  .work-section {
    margin-bottom: 3rem;
  }

  .work-section h2 {
    font-size: 1.5rem;
    margin-bottom: 1rem;
    color: var(--text-primary);
  }

  .work-description {
    font-size: 1.1rem;
    color: var(--text-secondary);
    line-height: 1.8;
    max-width: 800px;
  }

  /* 图片画廊 */
  .work-gallery {
    margin-top: 1rem;
  }

  .gallery-main {
    width: 100%;
    border-radius: 12px;
    overflow: hidden;
  }

  /* 左右交替布局 */
  .alternating-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
    margin-bottom: 3rem;
  }

  .alternating-layout.reverse {
    direction: rtl;
  }

  .alternating-layout.reverse .alternating-text {
    direction: ltr;
    text-align: left;
  }

  .alternating-image {
    border-radius: 12px;
    overflow: hidden;
  }

  .alternating-image img {
    width: 100%;
    height: auto;
    display: block;
  }

  .alternating-text h3 {
    font-size: 1.5rem;
    font-weight: 600;
    margin-bottom: 1rem;
    color: var(--text-primary);
  }

  .alternating-text p {
    font-size: 1rem;
    color: var(--text-secondary);
    line-height: 1.8;
  }

  /* 视频 */
  .work-video {
    position: relative;
    padding-bottom: 56.25%;
    height: 0;
    overflow: hidden;
    border-radius: 12px;
  }

  .work-video iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }

  /* 返回按钮 */
  .work-nav {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
  }

  .btn-back {
    color: var(--text-secondary);
    text-decoration: none;
    font-size: 1rem;
    transition: color 0.2s;
  }

  .btn-back:hover {
    color: var(--text-primary);
  }

  /* 页脚 - 与首页一致 */
  .site-footer {
    padding: 4rem 3rem;
    background: var(--bg-primary);
    border-top: 1px solid var(--border);
  }

  .footer-inner {
    max-width: 1400px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr auto auto;
    gap: 4rem;
    align-items: start;
  }

  .footer-brand h3 {
    font-size: 1.3rem;
    font-weight: 600;
    margin-bottom: 0.75rem;
    color: white;
  }

  .footer-brand p {
    color: var(--text-secondary);
    font-size: 0.95rem;
    max-width: 300px;
  }

  .footer-links {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .footer-links a {
    color: var(--text-secondary);
    text-decoration: none;
    font-size: 0.9rem;
    transition: color 0.2s;
  }

  .footer-links a:hover {
    color: white;
  }

  .footer-copyright {
    color: var(--text-secondary);
    font-size: 0.85rem;
  }

  @media (max-width: 768px) {
    .work-hero { height: 40vh; }
    .work-header { margin-top: -6rem; }
    .work-header h1 { font-size: 2rem; }
    .site-header { padding: 1rem 1.5rem; }
    .main-nav { gap: 1.5rem; }
    .alternating-layout {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
    .alternating-layout.reverse {
      direction: ltr;
    }
  }
</style>
