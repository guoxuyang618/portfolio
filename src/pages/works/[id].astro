---
import worksData from '../../content/works.json';
import config from '../../content/config.json';
import '../../styles/global.css';

export function getStaticPaths() {
  return worksData.works.map((work: any) => ({
    params: { id: work.id },
    props: { work }
  }));
}

const { work } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{work?.title || 'Project Detail'} - {config.site.name}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
</head>
<body>
  <!-- 顶部导航 -->
  <header class="site-header" id="siteHeader">
    <div class="header-inner">
      <a href="/" class="logo">
        <img src="/images/works/xuyang logo.png" alt="Xuyang Logo" class="logo-img" />
      </a>
      <nav class="main-nav">
        <a href="/" class="nav-link">Home</a>
        <a href="/works" class="nav-link active">Work</a>
        <a href="/about" class="nav-link">About</a>
      </nav>
      <a href="/about#contact" class="nav-cta">
        <span>Contact Me</span>
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17L17 7M17 7H7M17 7V17"/></svg>
      </a>
      <button class="hamburger" id="hamburgerBtn" aria-label="Toggle menu">
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
      </button>
    </div>
  </header>

  <!-- 移动端菜单 -->
  <div class="mobile-menu" id="mobileMenu">
    <nav class="mobile-nav">
      <a href="/" class="mobile-nav-link">Home</a>
      <a href="/works" class="mobile-nav-link active">Work</a>
      <a href="/about" class="mobile-nav-link">About</a>
      <a href="/about#contact" class="mobile-nav-cta">Contact Me</a>
    </nav>
  </div>

  <script>
    const header = document.getElementById('siteHeader');
    if (header) {
      window.addEventListener('scroll', () => {
        if (window.scrollY > 80) {
          header.classList.add('scrolled');
        } else {
          header.classList.remove('scrolled');
        }
      });
    }

    const hamburgerBtn = document.getElementById('hamburgerBtn');
    const mobileMenu = document.getElementById('mobileMenu');
    if (hamburgerBtn && mobileMenu) {
      hamburgerBtn.addEventListener('click', () => {
        hamburgerBtn.classList.toggle('active');
        mobileMenu.classList.toggle('active');
        document.body.classList.toggle('menu-open');
      });
    }
  </script>

  <!-- 作品 Hero 大图 -->
  <section class="work-hero">
    <div class="hero-bg">
      <img src={work?.cover} alt={work?.title} />
    </div>
    <div class="hero-gradient"></div>
  </section>

  <main class="work-detail">
    <div class="container">
      <!-- 作品标题区 -->
      <div class="work-header">
        <div class="work-header-top">
          <a href="/works" class="back-link">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
            <span>All Projects</span>
          </a>
        </div>
        <h1>{work?.title}</h1>
        <div class="work-meta-row">
          <div class="meta-tag">
            <span class="meta-label">Category</span>
            <span class="meta-value">{work?.category}</span>
          </div>
          <div class="meta-tag">
            <span class="meta-label">Year</span>
            <span class="meta-value">{work?.year}</span>
          </div>
        </div>
      </div>

      <!-- Project Overview -->
      <section class="work-section">
        <div class="section-grid">
          <div class="section-label">
            <span class="label-tag">01</span>
            <h2>Project Overview</h2>
          </div>
          <div class="section-content">
            <p class="large-text">{work?.description || 'No description available'}</p>
          </div>
        </div>
      </section>

      <!-- Main Showcase -->
      <section class="work-section">
        <div class="work-showcase">
          <img src={work?.cover} alt={work?.title} class="showcase-img" />
        </div>
      </section>

      <!-- Design Approach -->
      <section class="work-section">
        <div class="section-grid">
          <div class="section-label">
            <span class="label-tag">02</span>
            <h2>Design Approach</h2>
          </div>
          <div class="section-content">
            <div class="content-split">
              <div class="split-image">
                <img src="/images/works/2024/project-001.jpg" alt="Design Process">
              </div>
              <div class="split-text">
                <p>Detailed description of the design approach, user research, and interaction flows for this project. Showcasing the thinking process and solutions behind the design.</p>
                <p>Through in-depth user research and competitive analysis, we identified the core design direction, ensuring every design decision is evidence-based.</p>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- Visual Design -->
      <section class="work-section">
        <div class="section-grid">
          <div class="section-label">
            <span class="label-tag">03</span>
            <h2>Visual Design</h2>
          </div>
          <div class="section-content">
            <div class="content-split reverse">
              <div class="split-image">
                <img src="/images/works/2024/project-001.jpg" alt="Visual Design">
              </div>
              <div class="split-text">
                <p>Detailed description of the visual design, color usage, and layout for this project. Showcasing the final design outcomes and visual presentation.</p>
                <p>The color system was selected based on brand identity and target audience aesthetic preferences, ensuring consistency and professionalism in visual communication.</p>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- 交互体验 -->
      <section class="work-section">
        <div class="section-grid">
          <div class="section-label">
            <span class="label-tag">04</span>
            <h2>Interaction Design</h2>
          </div>
          <div class="section-content">
            <div class="content-split">
              <div class="split-image">
                <img src="/images/works/2024/project-001.jpg" alt="Interaction Design">
              </div>
              <div class="split-text">
                <p>Detailed description of the interaction design, user flows, and motion effects for this project. Demonstrating how interaction design enhances the user experience.</p>
                <p>Every micro-interaction has been meticulously refined to ensure smooth and intuitive user operations.</p>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- 视频展示 -->
      {work?.video && (
        <section class="work-section">
          <div class="section-grid">
            <div class="section-label">
              <span class="label-tag">05</span>
              <h2>Demo Video</h2>
            </div>
            <div class="section-content">
              <div class="work-video">
                <iframe
                  src={`https://player.bilibili.com/player.html?bvid=${work.video.id}&page=1`}
                  scrolling="no"
                  frameborder="no"
                  allowfullscreen="true">
                </iframe>
              </div>
            </div>
          </div>
        </section>
      )}

      <!-- 底部导航 -->
      <div class="work-nav">
        <a href="/works" class="nav-back">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
          <span>Back to All Projects</span>
        </a>
      </div>
    </div>
  </main>

  <!-- 页脚 -->
  <footer class="site-footer">
    <div class="footer-inner">
      <div class="footer-top">
        <div class="footer-brand">
          <div class="footer-logo">
            <img src="/images/works/xuyang logo.png" alt="Xuyang Logo" class="footer-logo-img" />
          </div>
          <p>{config.site.description}</p>
        </div>
        <div class="footer-nav">
          <div class="footer-col">
            <h4>Navigation</h4>
            <a href="/">Home</a>
            <a href="/works">Work</a>
            <a href="/about">About</a>
          </div>
        </div>
      </div>
      <div class="footer-bottom">
        <p>&copy; 2026 {config.site.name}. All rights reserved.</p>
      </div>
    </div>
  </footer>
</body>
</html>

<style>
  /* ===== 导航栏 ===== */
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 1000;
    padding: 1.8rem var(--container-padding);
    background: transparent;
    transition: all 0.4s var(--ease-out);
  }

  .site-header.scrolled {
    background: rgba(8, 8, 10, 0.92);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    padding-top: 0.9rem;
    padding-bottom: 0.9rem;
    border-bottom: 1px solid var(--border);
  }

  .header-inner {
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    text-decoration: none;
    color: var(--text-primary);
  }

  .logo-img {
    height: 48px;
    width: auto;
    display: block;
    object-fit: contain;
  }

  .main-nav { display: flex; gap: 2.5rem; align-items: center; }

  .nav-link {
    color: var(--text-secondary);
    text-decoration: none;
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    transition: color 0.3s ease;
    position: relative;
    padding: 0.25rem 0;
  }

  .nav-link.active, .nav-link:hover { color: var(--text-primary); }

  .nav-link::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 0;
    height: 1.5px;
    background: var(--accent);
    transition: width 0.3s var(--ease-out);
  }

  .nav-link.active::after, .nav-link:hover::after { width: 100%; }

  .nav-cta {
    color: #08080a;
    text-decoration: none;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    padding: 0.6rem 1.4rem;
    background: var(--accent);
    border: 1px solid var(--accent);
    border-radius: 0;
    transition: all 0.3s ease;
  }

  .nav-cta:hover {
    background: #3dd4c6;
    border-color: #3dd4c6;
  }

  /* 汉堡菜单按钮 */
  .hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 5px;
    width: 36px;
    height: 36px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    z-index: 1001;
  }

  .hamburger-line {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--text-primary);
    transition: all 0.3s ease;
    border-radius: 1px;
  }

  .hamburger.active .hamburger-line:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }

  .hamburger.active .hamburger-line:nth-child(2) {
    opacity: 0;
  }

  .hamburger.active .hamburger-line:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  .mobile-menu {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100vh;
    background: rgba(8, 8, 12, 0.97);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    z-index: 999;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
  }

  .mobile-menu.active {
    opacity: 1;
    pointer-events: all;
  }

  .mobile-nav {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    height: 100%;
    gap: 2rem;
  }

  .mobile-nav-link {
    color: var(--text-secondary);
    text-decoration: none;
    font-size: 1.5rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    transition: color 0.3s ease;
  }

  .mobile-nav-link.active,
  .mobile-nav-link:hover {
    color: var(--text-primary);
  }

  .mobile-nav-cta {
    display: inline-flex;
    align-items: center;
    margin-top: 1rem;
    padding: 0.9rem 2.5rem;
    background: var(--accent);
    color: #000;
    text-decoration: none;
    font-weight: 700;
    font-size: 1rem;
    letter-spacing: 0.06em;
    border-radius: 0;
    transition: all 0.3s ease;
  }

  .mobile-nav-cta:hover {
    background: #3dd4c6;
  }

  body.menu-open {
    overflow: hidden;
  }


  /* ===== 作品 Hero ===== */
  .work-hero {
    width: 100%;
    height: 65vh;
    min-height: 450px;
    position: relative;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
  }

  .hero-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: brightness(0.5);
  }

  .hero-gradient {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(8,8,10,0.3) 0%, rgba(8,8,10,0.1) 50%, var(--bg-primary) 100%);
  }

  /* ===== 作品详情 ===== */
  .work-detail {
    background: var(--bg-primary);
    padding-bottom: 4rem;
  }

  .work-header {
    margin-top: -8rem;
    position: relative;
    z-index: 1;
    padding-bottom: 3rem;
    border-bottom: 1px solid var(--border);
    margin-bottom: 4rem;
  }

  .work-header-top {
    margin-bottom: 1.5rem;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--text-secondary);
    text-decoration: none;
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    transition: color 0.2s;
  }

  .back-link:hover {
    color: var(--text-primary);
  }

  .work-header h1 {
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    font-weight: 700;
    margin-bottom: 1.5rem;
    line-height: 1.15;
  }

  .work-meta-row {
    display: flex;
    gap: 2.5rem;
  }

  .meta-tag {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .meta-label {
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-tertiary);
  }

  .meta-value {
    font-size: 0.95rem;
    color: var(--text-primary);
    font-weight: 500;
  }

  /* ===== Section 通用 ===== */
  .work-section {
    margin-bottom: 5rem;
  }

  .section-grid {
    display: grid;
    grid-template-columns: 250px 1fr;
    gap: 4rem;
    align-items: flex-start;
  }

  .section-label {
    position: sticky;
    top: 6rem;
  }

  .label-tag {
    display: block;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    color: var(--accent);
    margin-bottom: 0.5rem;
  }

  .section-label h2 {
    font-size: 1.3rem;
    font-weight: 600;
    margin-bottom: 0;
    color: var(--text-primary);
  }

  .large-text {
    font-size: 1.15rem;
    color: var(--text-secondary);
    line-height: 1.85;
    max-width: 700px;
  }

  /* ===== 展示图 ===== */
  .work-showcase {
    border-radius: 16px;
    overflow: hidden;
    border: 1px solid var(--border);
  }

  .showcase-img {
    width: 100%;
    display: block;
  }

  /* ===== 图文分割 ===== */
  .content-split {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 3rem;
    align-items: center;
  }

  .content-split.reverse {
    grid-template-columns: 1fr 1.2fr;
  }

  .content-split.reverse .split-image {
    order: 2;
  }

  .content-split.reverse .split-text {
    order: 1;
  }

  .split-image {
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid var(--border);
  }

  .split-image img {
    width: 100%;
    height: auto;
    display: block;
    transition: transform 0.5s var(--ease-out);
  }

  .split-image:hover img {
    transform: scale(1.03);
  }

  .split-text p {
    font-size: 1rem;
    color: var(--text-secondary);
    line-height: 1.8;
    margin-bottom: 1rem;
  }

  .split-text p:last-child {
    margin-bottom: 0;
  }

  /* ===== 视频 ===== */
  .work-video {
    position: relative;
    padding-bottom: 56.25%;
    height: 0;
    overflow: hidden;
    border-radius: 12px;
    border: 1px solid var(--border);
  }

  .work-video iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }

  /* ===== 底部导航 ===== */
  .work-nav {
    margin-top: 4rem;
    padding-top: 2.5rem;
    border-top: 1px solid var(--border);
  }

  .nav-back {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    color: var(--text-secondary);
    text-decoration: none;
    font-size: 0.85rem;
    font-weight: 500;
    transition: all 0.25s ease;
    padding: 0.7rem 1.5rem;
    border: 1px solid var(--border);
    border-radius: 0;
  }

  .nav-back:hover {
    color: var(--text-primary);
    border-color: var(--border-hover);
    transform: translateX(-4px);
  }

  /* ===== 页脚 ===== */
  .site-footer {
    padding: 4rem var(--container-padding) 2rem;
    background: var(--bg-primary);
    border-top: 1px solid var(--border);
  }

  .footer-inner { width: 100%; }

  .footer-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    padding-bottom: 3rem;
    border-bottom: 1px solid var(--border);
    margin-bottom: 2rem;
  }

  .footer-logo {
    display: flex;
    align-items: center;
    margin-bottom: 0.75rem;
  }

  .footer-logo-img {
    height: 48px;
    width: auto;
    object-fit: contain;
  }

  .footer-brand p { color: var(--text-tertiary); font-size: 0.9rem; max-width: 280px; }
  .footer-nav { display: flex; gap: 5rem; }

  .footer-col h4 {
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-secondary);
    margin-bottom: 1rem;
  }

  .footer-col a {
    display: block;
    color: var(--text-tertiary);
    text-decoration: none;
    font-size: 0.9rem;
    padding: 0.3rem 0;
    transition: color 0.2s;
  }

  .footer-col a:hover { color: var(--text-primary); }

  .footer-bottom p { color: var(--text-tertiary); font-size: 0.8rem; }

  /* ===== 响应式 ===== */
  @media (max-width: 1024px) {
    .section-grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
    .section-label {
      position: static;
    }
  }

  @media (max-width: 768px) {
    .site-header { padding: 1rem 1.5rem; }
    .site-header.scrolled { padding-top: 0.7rem; padding-bottom: 0.7rem; }
    .logo-img { height: 40px; }
    .main-nav { display: none; }
    .nav-cta { display: none; }
    .hamburger { display: flex; }
    .mobile-menu { display: block; }
    .work-hero { height: 45vh; min-height: 300px; }
    .work-header { margin-top: -5rem; margin-bottom: 3rem; }
    .work-header h1 { font-size: 2rem; }
    .work-meta-row { gap: 1.5rem; }
    .content-split, .content-split.reverse {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
    .content-split.reverse .split-image { order: 0; }
    .content-split.reverse .split-text { order: 0; }
    .work-section { margin-bottom: 3rem; }
    .footer-top { flex-direction: column; gap: 2rem; }
    .footer-nav { align-self: flex-end; }
  }
</style>
