---
import worksData from '../../content/works.json';
import config from '../../content/config.json';
import '../../styles/global.css';

export function getStaticPaths() {
  return worksData.works.map((work: any) => ({
    params: { id: work.id },
    props: { work }
  }));
}

const { work } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{work?.title || 'Project Detail'} - {config.site.name}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
</head>
<body>
  <!-- 顶部导航 -->
  <header class="site-header" id="siteHeader">
    <div class="header-inner">
      <a href="/" class="logo">
        <img src="/images/works/xuyang logo.png" alt="Xuyang Logo" class="logo-img" />
      </a>
      <nav class="main-nav">
        <a href="/" class="nav-link">Home</a>
        <a href="/works" class="nav-link active">Work</a>
        <a href="/about" class="nav-link">About</a>
      </nav>
      <a href="/about#contact" class="nav-cta">
        <span>Contact Me</span>
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17L17 7M17 7H7M17 7V17"/></svg>
      </a>
      <!-- 汉堡菜单按钮（移动端显示） -->
      <button class="hamburger" id="hamburger" aria-label="Toggle menu">
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
      </button>
    </div>
  </header>

  <script>
    const header = document.getElementById('siteHeader');
    if (header) {
      window.addEventListener('scroll', () => {
        if (window.scrollY > 80) {
          header.classList.add('scrolled');
        } else {
          header.classList.remove('scrolled');
        }
      });
    }

    // 汉堡菜单交互
    const hamburger = document.getElementById('hamburger');
    const mainNav = document.querySelector('.main-nav');
    if (hamburger && mainNav) {
      hamburger.addEventListener('click', () => {
        hamburger.classList.toggle('active');
        mainNav.classList.toggle('open');
      });
      mainNav.querySelectorAll('.nav-link').forEach(link => {
        link.addEventListener('click', () => {
          hamburger.classList.remove('active');
          mainNav.classList.remove('open');
        });
      });
    }
  </script>

  <!-- 灯箱交互脚本 -->
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const lightbox = document.getElementById('lightbox');
      const lightboxImg = document.getElementById('lightboxImg') as HTMLImageElement;
      const lightboxTitle = document.getElementById('lightboxTitle');
      const lightboxText = document.getElementById('lightboxText');
      const lightboxClose = document.getElementById('lightboxClose');
      const lightboxPrev = document.getElementById('lightboxPrev');
      const lightboxNext = document.getElementById('lightboxNext');
      const lightboxOverlay = document.getElementById('lightboxOverlay');

      // 收集所有可点击图片的数据
      const triggers = document.querySelectorAll('.lightbox-trigger');
      const imagesData: { src: string; title: string; text: string }[] = [];
      
      triggers.forEach((trigger) => {
        const img = trigger.querySelector('img') as HTMLImageElement;
        const section = trigger.closest('.work-section');
        const sectionTitle = section?.querySelector('.section-label h2')?.textContent || '';
        const sectionText = section?.querySelector('.split-text p')?.textContent || '';
        
        imagesData.push({
          src: img?.src || '',
          title: sectionTitle,
          text: sectionText
        });
      });

      let currentIndex = 0;

      function showImage(index: number) {
        if (index < 0 || index >= imagesData.length) return;
        currentIndex = index;
        const data = imagesData[currentIndex];
        if (lightboxImg) lightboxImg.src = data.src;
        if (lightboxImg) lightboxImg.alt = data.title;
        if (lightboxTitle) lightboxTitle.textContent = data.title;
        if (lightboxText) lightboxText.textContent = data.text;
      }

      function openLightbox(index: number) {
        showImage(index);
        lightbox?.classList.add('active');
        document.body.style.overflow = 'hidden';
      }

      function closeLightbox() {
        lightbox?.classList.remove('active');
        document.body.style.overflow = '';
      }

      // 点击图片打开灯箱
      triggers.forEach((trigger, idx) => {
        trigger.addEventListener('click', () => {
          openLightbox(idx);
        });
      });

      // 关闭按钮
      lightboxClose?.addEventListener('click', closeLightbox);

      // 点击遮罩关闭
      lightboxOverlay?.addEventListener('click', closeLightbox);

      // 上一张
      lightboxPrev?.addEventListener('click', () => {
        const newIndex = currentIndex > 0 ? currentIndex - 1 : imagesData.length - 1;
        showImage(newIndex);
      });

      // 下一张
      lightboxNext?.addEventListener('click', () => {
        const newIndex = currentIndex < imagesData.length - 1 ? currentIndex + 1 : 0;
        showImage(newIndex);
      });

      // 键盘支持
      document.addEventListener('keydown', (e) => {
        if (!lightbox?.classList.contains('active')) return;
        if (e.key === 'Escape') closeLightbox();
        if (e.key === 'ArrowLeft') {
          const newIndex = currentIndex > 0 ? currentIndex - 1 : imagesData.length - 1;
          showImage(newIndex);
        }
        if (e.key === 'ArrowRight') {
          const newIndex = currentIndex < imagesData.length - 1 ? currentIndex + 1 : 0;
          showImage(newIndex);
        }
      });
    });
  </script>

  <!-- 视频尺寸锁定 + 播放状态管理脚本 -->
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      // ===== 1. 用真实宽高比覆盖默认 aspect-ratio =====
      const videoContainers = document.querySelectorAll('.vertical-video, .dual-video-wrap');
      videoContainers.forEach((container) => {
        const video = container.querySelector('video');
        if (!video) return;

        function lockRealAspectRatio() {
          const w = video!.videoWidth;
          const h = video!.videoHeight;
          if (w && h) {
            (container as HTMLElement).style.aspectRatio = `${w} / ${h}`;
          }
        }

        if (video.readyState >= 1) {
          lockRealAspectRatio();
        } else {
          video.addEventListener('loadedmetadata', lockRealAspectRatio, { once: true });
        }

        // ===== 2. 播放状态管理：播放时隐藏覆盖层 =====
        video.addEventListener('play', () => {
          container.classList.add('is-playing');
        });
        video.addEventListener('pause', () => {
          container.classList.remove('is-playing');
        });
        video.addEventListener('ended', () => {
          container.classList.remove('is-playing');
        });

        // ===== 3. 点击覆盖层触发播放 =====
        const overlay = container.querySelector('.video-play-overlay');
        if (overlay) {
          overlay.addEventListener('click', () => {
            video.play();
          });
        }
      });
    });
  </script>

  <!-- 作品 Hero 大图 -->
  <section class="work-hero">
    <div class="hero-bg">
      <img src={work?.cover} alt={work?.title} />
    </div>
    <div class="hero-gradient"></div>
  </section>

  <main class="work-detail">
    <div class="container">
      <!-- 作品标题区 -->
      <div class="work-header">
        <h1>{work?.title}</h1>
        <div class="work-meta-row">
          <div class="meta-tag">
            <span class="meta-label">Category</span>
            <span class="meta-value">{work?.category}</span>
          </div>
          <div class="meta-tag">
            <span class="meta-label">Year</span>
            <span class="meta-value">{work?.year}</span>
          </div>
        </div>
      </div>

      <!-- Project Overview -->
      <section class="work-section">
        <div class="section-label-block">
          <span class="label-tag">01</span>
          <h2>Project Overview</h2>
        </div>
        <div class="content-vertical">
          <div class="vertical-text">
            <p>{work?.description || 'No description available'}</p>
          </div>
          {work?.overviewVideo ? (
            <div class="vertical-video overview-video">
              <video controls playsinline preload="metadata">
                <source src={work.overviewVideo} type="video/webm" />
                Your browser does not support the video tag.
              </video>
              <div class="video-play-overlay">
                <div class="play-btn">
                  <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor"><polygon points="5,3 19,12 5,21"/></svg>
                </div>
              </div>
            </div>
          ) : (
            <div class="vertical-image">
              <img src={work?.overviewImage || work?.cover} alt="Project Overview" />
            </div>
          )}
        </div>
      </section>

      <!-- 动态图文 Section：上文下图布局 -->
      {work?.images && work.images.map((img: any, idx: number) => (
        <section class="work-section">
          <div class="section-label-block">
            <span class="label-tag">{String(idx + 2).padStart(2, '0')}</span>
            <h2>{img.title}</h2>
          </div>
          <div class="content-vertical">
            <div class="vertical-text">
              <p>{img.text}</p>
            </div>
            {img.type === 'video' ? (
              <div class="vertical-video">
                <video controls playsinline preload="metadata" poster={img.poster || ''}>
                  <source src={img.src} type="video/mp4" />
                  Your browser does not support the video tag.
                </video>
                <div class="video-play-overlay">
                  <div class="play-btn">
                    <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor"><polygon points="5,3 19,12 5,21"/></svg>
                  </div>
                </div>
              </div>
            ) : img.type === 'dual-video' ? (
              <div class="dual-video-row">
                {img.videos && img.videos.map((v: any) => (
                  <div class="dual-video-item">
                    <div class="dual-video-wrap">
                      <video controls playsinline preload="metadata" poster={v.poster || ''}>
                        <source src={v.src} type="video/mp4" />
                        Your browser does not support the video tag.
                      </video>
                      <div class="video-play-overlay">
                        <div class="play-btn play-btn--sm">
                          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><polygon points="5,3 19,12 5,21"/></svg>
                        </div>
                      </div>
                    </div>
                    {v.caption && <p class="dual-video-caption">{v.caption}</p>}
                  </div>
                ))}
              </div>
            ) : (
              <div class={`vertical-image lightbox-trigger${img.noRadius ? ' no-radius' : ''}${img.objectFit === 'cover' ? ' img-cover' : ''}`} data-index={idx}>
                <img src={img.src} alt={img.title} />
              </div>
            )}
          </div>
        </section>
      ))}

      <!-- 视频展示 -->
      {work?.video && (
        <section class="work-section">
          <div class="section-grid">
            <div class="section-label">
              <span class="label-tag">05</span>
              <h2>Demo Video</h2>
            </div>
            <div class="section-content">
              <div class="work-video">
                <iframe
                  src={`https://player.bilibili.com/player.html?bvid=${work.video.id}&page=1`}
                  scrolling="no"
                  frameborder="no"
                  allowfullscreen="true">
                </iframe>
              </div>
            </div>
          </div>
        </section>
      )}

    </div>
  </main>

  <!-- 全屏灯箱 -->
  <div class="lightbox" id="lightbox">
    <div class="lightbox-overlay" id="lightboxOverlay"></div>
    <button class="lightbox-arrow lightbox-prev" id="lightboxPrev" aria-label="Previous image">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
    </button>
    <button class="lightbox-arrow lightbox-next" id="lightboxNext" aria-label="Next image">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 6 15 12 9 18"></polyline></svg>
    </button>
    <div class="lightbox-content">
      <div class="lightbox-image-wrap">
        <img id="lightboxImg" src="" alt="" />
      </div>
      <div class="lightbox-info">
        <h3 id="lightboxTitle"></h3>
        <p id="lightboxText"></p>
      </div>
    </div>
    <button class="lightbox-close" id="lightboxClose" aria-label="Close">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
    </button>
  </div>

  <!-- 页脚 -->
  <footer class="site-footer">
    <div class="footer-inner">
      <div class="footer-top">
        <div class="footer-brand">
          <div class="footer-logo">
            <img src="/images/works/xuyang logo.png" alt="Xuyang Logo" class="footer-logo-img" />
          </div>
          <p>{config.site.description}</p>
        </div>
        <div class="footer-nav">
          <div class="footer-col">
            <h4>Navigation</h4>
            <a href="/">Home</a>
            <a href="/works">Work</a>
            <a href="/about">About</a>
          </div>
        </div>
      </div>
      <div class="footer-bottom">
        <p>&copy; 2026 {config.site.name}. All rights reserved.</p>
      </div>
    </div>
  </footer>
</body>
</html>

<style>
  /* ===== 导航栏 ===== */
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 1000;
    padding: 1.8rem var(--container-padding);
    background: transparent;
    transition: all 0.4s var(--ease-out);
  }

  .site-header.scrolled {
    background: rgba(8, 8, 10, 0.92);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    padding-top: 0.9rem;
    padding-bottom: 0.9rem;
    border-bottom: 1px solid var(--border);
  }

  .header-inner {
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    text-decoration: none;
    color: var(--text-primary);
  }

  .logo-img {
    height: 48px;
    width: auto;
    display: block;
    object-fit: contain;
  }

  .main-nav { display: flex; gap: 2.5rem; align-items: center; }

  .nav-link {
    color: var(--text-secondary);
    text-decoration: none;
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    transition: color 0.3s ease;
    position: relative;
    padding: 0.25rem 0;
  }

  .nav-link.active, .nav-link:hover { color: var(--text-primary); }

  .nav-link::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 0;
    height: 1.5px;
    background: var(--accent);
    transition: width 0.3s var(--ease-out);
  }

  .nav-link.active::after, .nav-link:hover::after { width: 100%; }

  .nav-cta {
    color: #08080a;
    text-decoration: none;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    padding: 0.6rem 1.4rem;
    background: var(--accent);
    border: 1px solid var(--accent);
    border-radius: 0;
    transition: all 0.3s ease;
  }

  .nav-cta:hover {
    background: #3dd4c6;
    border-color: #3dd4c6;
  }

  /* ===== 汉堡菜单 ===== */
  .hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 5px;
    width: 32px;
    height: 32px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    z-index: 1001;
  }

  .hamburger-line {
    display: block;
    width: 22px;
    height: 2px;
    background: #fff;
    transition: all 0.3s ease;
    transform-origin: center;
  }

  .hamburger.active .hamburger-line:nth-child(1) {
    transform: rotate(45deg) translate(5px, 5px);
  }
  .hamburger.active .hamburger-line:nth-child(2) {
    opacity: 0;
  }
  .hamburger.active .hamburger-line:nth-child(3) {
    transform: rotate(-45deg) translate(5px, -5px);
  }

  /* ===== 作品 Hero ===== */
  .work-hero {
    width: 100%;
    height: 65vh;
    min-height: 450px;
    position: relative;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
  }

  .hero-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: brightness(0.5);
  }

  .hero-gradient {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(8,8,10,0.3) 0%, rgba(8,8,10,0.1) 50%, var(--bg-primary) 100%);
  }

  /* ===== 作品详情 ===== */
  .work-detail {
    background: var(--bg-primary);
    padding-bottom: 4rem;
  }

  .work-header {
    margin-top: -8rem;
    position: relative;
    z-index: 1;
    padding-bottom: 3rem;
    border-bottom: 1px solid var(--border);
    margin-bottom: 4rem;
  }

  .work-header h1 {
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    font-weight: 700;
    margin-bottom: 1.5rem;
    line-height: 1.15;
  }

  .work-meta-row {
    display: flex;
    gap: 2.5rem;
  }

  .meta-tag {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .meta-label {
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-tertiary);
  }

  .meta-value {
    font-size: 0.95rem;
    color: var(--text-primary);
    font-weight: 500;
  }

  /* ===== Section 通用 ===== */
  .work-section {
    margin-bottom: 5rem;
  }

  .section-grid {
    display: grid;
    grid-template-columns: 250px 1fr;
    gap: 4rem;
    align-items: flex-start;
  }

  .section-label {
    position: sticky;
    top: 6rem;
  }

  .label-tag {
    display: block;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    color: var(--accent);
    margin-bottom: 0.5rem;
  }

  .section-label h2 {
    font-size: 1.3rem;
    font-weight: 600;
    margin-bottom: 0;
    color: var(--text-primary);
  }

  .large-text {
    font-size: 1.15rem;
    color: var(--text-secondary);
    line-height: 1.85;
  }

  /* ===== 图文标题区域（两列布局） ===== */
  .section-label-block {
    margin-bottom: 2rem;
  }

  .section-label-block .label-tag {
    display: block;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    color: var(--accent);
    margin-bottom: 0.5rem;
  }

  .section-label-block h2 {
    font-size: 1.3rem;
    font-weight: 600;
    margin-bottom: 0;
    color: var(--text-primary);
  }

  /* ===== 图文分割 ===== */
  .content-split {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: flex-start;
  }

  .content-split.reverse {
    grid-template-columns: 1fr 1fr;
  }

  .content-split.reverse .split-image {
    order: 2;
  }

  .content-split.reverse .split-text {
    order: 1;
  }

  /* ===== 上文下图布局 ===== */
  .content-vertical {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .vertical-text p {
    font-size: 1rem;
    color: var(--text-secondary);
    line-height: 1.8;
    margin-bottom: 0;
  }

  .vertical-image {
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid var(--border);
    background: var(--bg-secondary, #141416);
    transition: border-color 0.35s ease, box-shadow 0.35s ease;
  }

  .vertical-image:hover {
    border-color: rgba(255, 255, 255, 0.12);
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.3);
  }

  .vertical-image.no-radius {
    border-radius: 0;
  }

  .vertical-image img {
    width: 100%;
    height: auto;
    display: block;
    transition: transform 0.5s var(--ease-out);
  }

  .vertical-image:hover img {
    transform: scale(1.015);
  }

  /* ===== 图片填充模式（object-fit: cover）===== */
  .vertical-image.img-cover {
    aspect-ratio: 16 / 9;
  }

  .vertical-image.img-cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* ===== Overview 视频（覆盖填充模式） ===== */
  .overview-video video {
    object-fit: cover;
  }

  /* ===== 内嵌视频 ===== */
  .vertical-video {
    position: relative;
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid var(--border);
    background: #0a0a0c;
    aspect-ratio: 16 / 9;
  }

  .vertical-video video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
    object-fit: contain;
  }

  /* ===== 视频未播放状态覆盖层 ===== */
  .video-play-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(180deg, transparent 40%, rgba(0,0,0,0.35) 100%);
    z-index: 2;
    cursor: pointer;
    transition: opacity 0.35s ease;
  }

  .play-btn {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.15);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 2px solid rgba(255, 255, 255, 0.3);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    transition: all 0.3s ease;
    padding-left: 3px;
  }

  .play-btn--sm {
    width: 48px;
    height: 48px;
  }

  .video-play-overlay:hover .play-btn {
    background: rgba(255, 255, 255, 0.25);
    border-color: rgba(255, 255, 255, 0.5);
    transform: scale(1.08);
  }

  /* 播放状态：隐藏覆盖层 */
  .is-playing .video-play-overlay {
    opacity: 0;
    pointer-events: none;
  }

