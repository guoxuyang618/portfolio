---
import worksData from '../../content/works.json';
import config from '../../content/config.json';
import '../../styles/global.css';

export function getStaticPaths() {
  return worksData.works.map((work: any) => ({
    params: { id: work.id },
    props: { work }
  }));
}

const { work } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{work?.title || 'Project Detail'} - {config.site.name}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
</head>
<body>
  <!-- 顶部导航 -->
  <header class="site-header" id="siteHeader">
    <div class="header-inner">
      <a href="/" class="logo">
        <img src="/images/works/xuyang logo.png" alt="Xuyang Logo" class="logo-img" />
      </a>
      <nav class="main-nav">
        <a href="/" class="nav-link">Home</a>
        <a href="/works" class="nav-link active">Work</a>
        <a href="/about" class="nav-link">About</a>
      </nav>
      <a href="/about#contact" class="nav-cta">
        <span>Contact Me</span>
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17L17 7M17 7H7M17 7V17"/></svg>
      </a>
    </div>
  </header>

  <script>
    const header = document.getElementById('siteHeader');
    if (header) {
      window.addEventListener('scroll', () => {
        if (window.scrollY > 80) {
          header.classList.add('scrolled');
        } else {
          header.classList.remove('scrolled');
        }
      });
    }
  </script>

  <!-- 灯箱交互脚本 -->
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const lightbox = document.getElementById('lightbox');
      const lightboxImg = document.getElementById('lightboxImg') as HTMLImageElement;
      const lightboxTitle = document.getElementById('lightboxTitle');
      const lightboxText = document.getElementById('lightboxText');
      const lightboxClose = document.getElementById('lightboxClose');
      const lightboxPrev = document.getElementById('lightboxPrev');
      const lightboxNext = document.getElementById('lightboxNext');
      const lightboxOverlay = document.getElementById('lightboxOverlay');

      // 收集所有可点击图片的数据
      const triggers = document.querySelectorAll('.lightbox-trigger');
      const imagesData: { src: string; title: string; text: string }[] = [];
      
      triggers.forEach((trigger) => {
        const img = trigger.querySelector('img') as HTMLImageElement;
        const section = trigger.closest('.work-section');
        const sectionTitle = section?.querySelector('.section-label h2')?.textContent || '';
        const sectionText = section?.querySelector('.split-text p')?.textContent || '';
        
        imagesData.push({
          src: img?.src || '',
          title: sectionTitle,
          text: sectionText
        });
      });

      let currentIndex = 0;

      function showImage(index: number) {
        if (index < 0 || index >= imagesData.length) return;
        currentIndex = index;
        const data = imagesData[currentIndex];
        if (lightboxImg) lightboxImg.src = data.src;
        if (lightboxImg) lightboxImg.alt = data.title;
        if (lightboxTitle) lightboxTitle.textContent = data.title;
        if (lightboxText) lightboxText.textContent = data.text;
      }

      function openLightbox(index: number) {
        showImage(index);
        lightbox?.classList.add('active');
        document.body.style.overflow = 'hidden';
      }

      function closeLightbox() {
        lightbox?.classList.remove('active');
        document.body.style.overflow = '';
      }

      // 点击图片打开灯箱
      triggers.forEach((trigger, idx) => {
        trigger.addEventListener('click', () => {
          openLightbox(idx);
        });
      });

      // 关闭按钮
      lightboxClose?.addEventListener('click', closeLightbox);

      // 点击遮罩关闭
      lightboxOverlay?.addEventListener('click', closeLightbox);

      // 上一张
      lightboxPrev?.addEventListener('click', () => {
        const newIndex = currentIndex > 0 ? currentIndex - 1 : imagesData.length - 1;
        showImage(newIndex);
      });

      // 下一张
      lightboxNext?.addEventListener('click', () => {
        const newIndex = currentIndex < imagesData.length - 1 ? currentIndex + 1 : 0;
        showImage(newIndex);
      });

      // 键盘支持
      document.addEventListener('keydown', (e) => {
        if (!lightbox?.classList.contains('active')) return;
        if (e.key === 'Escape') closeLightbox();
        if (e.key === 'ArrowLeft') {
          const newIndex = currentIndex > 0 ? currentIndex - 1 : imagesData.length - 1;
          showImage(newIndex);
        }
        if (e.key === 'ArrowRight') {
          const newIndex = currentIndex < imagesData.length - 1 ? currentIndex + 1 : 0;
          showImage(newIndex);
        }
      });
    });
  </script>

  <!-- 作品 Hero 大图 -->
  <section class="work-hero">
    <div class="hero-bg">
      <img src={work?.cover} alt={work?.title} />
    </div>
    <div class="hero-gradient"></div>
  </section>

  <main class="work-detail">
    <div class="container">
      <!-- 作品标题区 -->
      <div class="work-header">
        <div class="work-header-top">
          <a href="/works" class="back-link">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
            <span>All Projects</span>
          </a>
        </div>
        <h1>{work?.title}</h1>
        <div class="work-meta-row">
          <div class="meta-tag">
            <span class="meta-label">Category</span>
            <span class="meta-value">{work?.category}</span>
          </div>
          <div class="meta-tag">
            <span class="meta-label">Year</span>
            <span class="meta-value">{work?.year}</span>
          </div>
        </div>
      </div>

      <!-- Project Overview -->
      <section class="work-section">
        <div class="section-grid">
          <div class="section-label">
            <span class="label-tag">01</span>
            <h2>Project Overview</h2>
          </div>
          <div class="section-content">
            <p class="large-text">{work?.description || 'No description available'}</p>
          </div>
        </div>
      </section>

      <!-- Main Showcase -->
      <section class="work-section">
        <div class="work-showcase">
          <img src={work?.cover} alt={work?.title} class="showcase-img" />
        </div>
      </section>

      <!-- 动态图文 Section：保持左图右文 / 左文右图交替 -->
      {work?.images && work.images.map((img: any, idx: number) => (
        <section class="work-section">
          <div class="section-grid">
            <div class="section-label">
              <span class="label-tag">{String(idx + 2).padStart(2, '0')}</span>
              <h2>{img.title}</h2>
            </div>
            <div class="section-content">
              <div class={`content-split ${idx % 2 !== 0 ? 'reverse' : ''}`}>
                <div class="split-image lightbox-trigger" data-index={idx}>
                  <img src={img.src} alt={img.title} />
                  <div class="image-overlay">
                    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7"/></svg>
                  </div>
                </div>
                <div class="split-text">
                  <p>{img.text}</p>
                </div>
              </div>
            </div>
          </div>
        </section>
      ))}

      <!-- 视频展示 -->
      {work?.video && (
        <section class="work-section">
          <div class="section-grid">
            <div class="section-label">
              <span class="label-tag">05</span>
              <h2>Demo Video</h2>
            </div>
            <div class="section-content">
              <div class="work-video">
                <iframe
                  src={`https://player.bilibili.com/player.html?bvid=${work.video.id}&page=1`}
                  scrolling="no"
                  frameborder="no"
                  allowfullscreen="true">
                </iframe>
              </div>
            </div>
          </div>
        </section>
      )}

      <!-- 底部导航 -->
      <div class="work-nav">
        <a href="/works" class="nav-back">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
          <span>Back to All Projects</span>
        </a>
      </div>
    </div>
  </main>

  <!-- 全屏灯箱 -->
  <div class="lightbox" id="lightbox">
    <div class="lightbox-overlay" id="lightboxOverlay"></div>
    <button class="lightbox-arrow lightbox-prev" id="lightboxPrev" aria-label="Previous image">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
    </button>
    <button class="lightbox-arrow lightbox-next" id="lightboxNext" aria-label="Next image">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 6 15 12 9 18"></polyline></svg>
    </button>
    <div class="lightbox-content">
      <div class="lightbox-image-wrap">
        <img id="lightboxImg" src="" alt="" />
      </div>
      <div class="lightbox-info">
        <h3 id="lightboxTitle"></h3>
        <p id="lightboxText"></p>
      </div>
    </div>
    <button class="lightbox-close" id="lightboxClose" aria-label="Close">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
    </button>
  </div>

  <!-- 页脚 -->
  <footer class="site-footer">
    <div class="footer-inner">
      <div class="footer-top">
        <div class="footer-brand">
          <div class="footer-logo">
            <img src="/images/works/xuyang logo.png" alt="Xuyang Logo" class="footer-logo-img" />
          </div>
          <p>{config.site.description}</p>
        </div>
        <div class="footer-nav">
          <div class="footer-col">
            <h4>Navigation</h4>
            <a href="/">Home</a>
            <a href="/works">Work</a>
            <a href="/about">About</a>
          </div>
        </div>
      </div>
      <div class="footer-bottom">
        <p>&copy; 2026 {config.site.name}. All rights reserved.</p>
      </div>
    </div>
  </footer>
</body>
</html>

<style>
  /* ===== 导航栏 ===== */
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 1000;
    padding: 1.8rem var(--container-padding);
    background: transparent;
    transition: all 0.4s var(--ease-out);
  }

  .site-header.scrolled {
    background: rgba(8, 8, 10, 0.92);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    padding-top: 0.9rem;
    padding-bottom: 0.9rem;
    border-bottom: 1px solid var(--border);
  }

  .header-inner {
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    text-decoration: none;
    color: var(--text-primary);
  }

  .logo-img {
    height: 48px;
    width: auto;
    display: block;
    object-fit: contain;
  }

  .main-nav { display: flex; gap: 2.5rem; align-items: center; }

  .nav-link {
    color: var(--text-secondary);
    text-decoration: none;
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    transition: color 0.3s ease;
    position: relative;
    padding: 0.25rem 0;
  }

  .nav-link.active, .nav-link:hover { color: var(--text-primary); }

  .nav-link::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 0;
    height: 1.5px;
    background: var(--accent);
    transition: width 0.3s var(--ease-out);
  }

  .nav-link.active::after, .nav-link:hover::after { width: 100%; }

  .nav-cta {
    color: #08080a;
    text-decoration: none;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    padding: 0.6rem 1.4rem;
    background: var(--accent);
    border: 1px solid var(--accent);
    border-radius: 0;
    transition: all 0.3s ease;
  }

  .nav-cta:hover {
    background: #3dd4c6;
    border-color: #3dd4c6;
  }

  /* ===== 作品 Hero ===== */
  .work-hero {
    width: 100%;
    height: 65vh;
    min-height: 450px;
    position: relative;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
  }

  .hero-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: brightness(0.5);
  }

  .hero-gradient {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(8,8,10,0.3) 0%, rgba(8,8,10,0.1) 50%, var(--bg-primary) 100%);
  }

  /* ===== 作品详情 ===== */
  .work-detail {
    background: var(--bg-primary);
    padding-bottom: 4rem;
  }

  .work-header {
    margin-top: -8rem;
    position: relative;
    z-index: 1;
    padding-bottom: 3rem;
    border-bottom: 1px solid var(--border);
    margin-bottom: 4rem;
  }

  .work-header-top {
    margin-bottom: 1.5rem;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--text-secondary);
    text-decoration: none;
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    transition: color 0.2s;
  }

  .back-link:hover {
    color: var(--text-primary);
  }

  .work-header h1 {
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    font-weight: 700;
    margin-bottom: 1.5rem;
    line-height: 1.15;
  }

  .work-meta-row {
    display: flex;
    gap: 2.5rem;
  }

  .meta-tag {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .meta-label {
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-tertiary);
  }

  .meta-value {
    font-size: 0.95rem;
    color: var(--text-primary);
    font-weight: 500;
  }

  /* ===== Section 通用 ===== */
  .work-section {
    margin-bottom: 5rem;
  }

  .section-grid {
    display: grid;
    grid-template-columns: 250px 1fr;
    gap: 4rem;
    align-items: flex-start;
  }

  .section-label {
    position: sticky;
    top: 6rem;
  }

  .label-tag {
    display: block;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    color: var(--accent);
    margin-bottom: 0.5rem;
  }

  .section-label h2 {
    font-size: 1.3rem;
    font-weight: 600;
    margin-bottom: 0;
    color: var(--text-primary);
  }

  .large-text {
    font-size: 1.15rem;
    color: var(--text-secondary);
    line-height: 1.85;
    max-width: 700px;
  }

  /* ===== 展示图 ===== */
  .work-showcase {
    border-radius: 16px;
    overflow: hidden;
    border: 1px solid var(--border);
  }

  .showcase-img {
    width: 100%;
    display: block;
  }

  /* ===== 图文分割 ===== */
  .content-split {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 3rem;
    align-items: center;
  }

  .content-split.reverse {
    grid-template-columns: 1fr 1.2fr;
  }

  .content-split.reverse .split-image {
    order: 2;
  }

  .content-split.reverse .split-text {
    order: 1;
  }

  .split-image {
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid var(--border);
  }

  .split-image img {
    width: 100%;
    height: auto;
    display: block;
    transition: transform 0.5s var(--ease-out);
  }

  .split-image:hover img {
    transform: scale(1.03);
  }

  .split-text p {
    font-size: 1rem;
    color: var(--text-secondary);
    line-height: 1.8;
    margin-bottom: 1rem;
  }

  .split-text p:last-child {
    margin-bottom: 0;
  }

  /* ===== 图片点击触发器 ===== */
  .lightbox-trigger {
    cursor: pointer;
    position: relative;
  }

  .lightbox-trigger .image-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.4);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.3s ease;
    border-radius: 12px;
  }

  .lightbox-trigger:hover .image-overlay {
    opacity: 1;
  }

  .lightbox-trigger .image-overlay svg {
    color: #fff;
  }

  /* ===== 全屏灯箱 ===== */
  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: none;
    align-items: center;
    justify-content: center;
  }

  .lightbox.active {
    display: flex;
  }

  .lightbox-overlay {
    position: absolute;
    inset: 0;
    background: rgba(18, 18, 22, 0.98);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
  }

  .lightbox-content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    max-width: 65%;
    width: 100%;
    height: 100vh;
    padding-top: 5vh;
    box-sizing: border-box;
  }

  .lightbox-image-wrap {
    width: 100%;
    height: 60vh;
    min-height: 60vh;
    max-height: 60vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    border-radius: 4px;
    flex-shrink: 0;
  }

  .lightbox-image-wrap img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    display: block;
    border-radius: 4px;
    box-shadow: 0 8px 40px rgba(0, 0, 0, 0.4);
  }

  .lightbox-info {
    width: 100%;
    margin-top: 1.5rem;
    text-align: left;
    flex-shrink: 0;
  }

  .lightbox-info h3 {
    font-size: 1.3rem;
    font-weight: 600;
    color: #fff;
    margin-bottom: 0.6rem;
    letter-spacing: 0.02em;
  }

  .lightbox-info p {
    font-size: 0.92rem;
    color: rgba(255, 255, 255, 0.7);
    line-height: 1.7;
    max-width: 100%;
  }

  .lightbox-close {
    position: absolute;
    top: 1.5rem;
    right: 1.5rem;
    z-index: 3;
    background: none;
    border: none;
    color: rgba(255, 255, 255, 0.6);
    cursor: pointer;
    padding: 0.5rem;
    transition: color 0.2s ease;
  }

  .lightbox-close:hover {
    color: #fff;
  }

  .lightbox-arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 3;
    background: none;
    border: 2px solid rgba(255, 255, 255, 0.3);
    color: rgba(255, 255, 255, 0.7);
    cursor: pointer;
    width: 52px;
    height: 52px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.25s ease;
  }

  .lightbox-arrow:hover {
    border-color: rgba(255, 255, 255, 0.7);
    color: #fff;
    background: rgba(255, 255, 255, 0.08);
  }

  .lightbox-prev {
    left: 2.5rem;
  }

  .lightbox-next {
    right: 2.5rem;
  }

  /* ===== 视频 ===== */
  .work-video {
    position: relative;
    padding-bottom: 56.25%;
    height: 0;
    overflow: hidden;
    border-radius: 12px;
    border: 1px solid var(--border);
  }

  .work-video iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }

  /* ===== 底部导航 ===== */
  .work-nav {
    margin-top: 4rem;
    padding-top: 2.5rem;
    border-top: 1px solid var(--border);
  }

  .nav-back {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    color: var(--text-secondary);
    text-decoration: none;
    font-size: 0.85rem;
    font-weight: 500;
    transition: all 0.25s ease;
    padding: 0.7rem 1.5rem;
    border: 1px solid var(--border);
    border-radius: 0;
  }

  .nav-back:hover {
    color: var(--text-primary);
    border-color: var(--border-hover);
    transform: translateX(-4px);
  }

  /* ===== 页脚 ===== */
  .site-footer {
    padding: 4rem var(--container-padding) 2rem;
    background: var(--bg-primary);
    border-top: 1px solid var(--border);
  }

  .footer-inner { width: 100%; }

  .footer-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    padding-bottom: 3rem;
    border-bottom: 1px solid var(--border);
    margin-bottom: 2rem;
  }

  .footer-logo {
    display: flex;
    align-items: center;
    margin-bottom: 0.75rem;
  }

  .footer-logo-img {
    height: 48px;
    width: auto;
    object-fit: contain;
  }

  .footer-brand p { color: var(--text-tertiary); font-size: 0.9rem; max-width: 280px; }
  .footer-nav { display: flex; gap: 5rem; }

  .footer-col h4 {
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-secondary);
    margin-bottom: 1rem;
  }

  .footer-col a {
    display: block;
    color: var(--text-tertiary);
    text-decoration: none;
    font-size: 0.9rem;
    padding: 0.3rem 0;
    transition: color 0.2s;
  }

  .footer-col a:hover { color: var(--text-primary); }

  .footer-bottom p { color: var(--text-tertiary); font-size: 0.8rem; }

  /* ===== 响应式 ===== */
  @media (max-width: 1024px) {
