---
import config from '../content/config.json';
import about from '../content/about.json';
import '../styles/global.css';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>About - {config.site.name}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
</head>
<body>
  <!-- 顶部导航 -->
  <header class="site-header" id="siteHeader">
    <div class="header-inner">
      <a href="/" class="logo">
        <img src="/common/logo.webp" alt="Xuyang Logo" class="logo-img" />
      </a>
      <div class="nav-right">
        <nav class="main-nav" id="mainNav">
          <a href="/" class="nav-link" data-i18n="nav.home">Home</a>
          <a href="/works" class="nav-link" data-i18n="nav.work">Work</a>
          <a href="/about" class="nav-link active" data-i18n="nav.about">About</a>
        </nav>
        <button class="lang-toggle" id="langToggle" aria-label="Toggle language">
          <img src="/common/translate-icon.webp" alt="Language" class="lang-icon" />
          <span class="lang-label">EN</span>
        </button>
        <a href="#contact" class="nav-cta">
          <span data-i18n="nav.contact">Contact Me</span>
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17L17 7M17 7H7M17 7V17"/></svg>
        </a>
        <button class="hamburger" id="hamburger" aria-label="Toggle menu">
          <span class="hamburger-line"></span>
          <span class="hamburger-line"></span>
          <span class="hamburger-line"></span>
        </button>
      </div>
    </div>
  </header>

  <script>
    const header = document.getElementById('siteHeader');
    if (header) {
      window.addEventListener('scroll', () => {
        if (window.scrollY > 80) {
          header.classList.add('scrolled');
        } else {
          header.classList.remove('scrolled');
        }
      });
    }

    const hamburger = document.getElementById('hamburger');
    const mainNav = document.getElementById('mainNav');
    if (hamburger && mainNav) {
      hamburger.addEventListener('click', () => {
        hamburger.classList.toggle('active');
        mainNav.classList.toggle('open');
      });
      mainNav.querySelectorAll('.nav-link').forEach(link => {
        link.addEventListener('click', () => {
          hamburger.classList.remove('active');
          mainNav.classList.remove('open');
        });
      });
    }
  </script>

  <main>
    <!-- Hero 区域 -->
    <section class="about-hero">
      <div class="hero-content">
        <span class="hero-badge" data-i18n="about.heroBadge">About</span>
        <h1 data-i18n="about.heroTitle">Design Philosophy</h1>
        <p class="hero-desc">{config.site.description}</p>
      </div>
    </section>

    <!-- 关于介绍 -->
    <section class="about-section">
      <div class="about-inner">
        <div class="about-grid">
          <div class="about-label">
            <span class="label-tag" data-i18n="about.philosophyTag">Design Philosophy</span>
          </div>
          <div class="about-content">
            <p class="about-text-large" data-i18n="about.philosophyText1">I am a seasoned game interaction designer with extensive hands-on experience, dedicated to pushing the boundaries of player experience. My career began with the iconic FPS franchise CrossFire, and I am currently defining the next-generation interaction standards for shooters in Counter-Strike: Future.</p>
            <p class="about-text" data-i18n="about.philosophyText2">I don't just design interfaces — I design "feelings." From the instant feedback of pulling a trigger to the emotional connection of a grand worldview, I excel at using UE5, C4D and AIGC technologies to transform abstract concepts into tangible interactive experiences. With a deep understanding of FPS at my core, I also draw inspiration from MOBA, Roguelike and card game genres, striving to find the perfect balance between business objectives and player experience.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- 数据亮点 -->
    <section class="highlights-section">
      <div class="highlights-inner">
        <div class="highlight-card">
          <span class="highlight-number">5+</span>
          <span class="highlight-label" data-i18n-html="about.statProjects">Projects<br/>Delivered</span>
        </div>
        <div class="highlight-card">
          <span class="highlight-number">5</span>
          <span class="highlight-label" data-i18n-html="about.statCategories">Design<br/>Categories</span>
        </div>
        <div class="highlight-card">
          <span class="highlight-number">100%</span>
          <span class="highlight-label" data-i18n-html="about.statPassion">Design<br/>Passion</span>
        </div>
        <div class="highlight-card">
          <span class="highlight-number">2026</span>
          <span class="highlight-label" data-i18n-html="about.statLatest">Latest<br/>Projects</span>
        </div>
      </div>
    </section>

    <!-- 技能和服务 -->
    <section class="services-section">
      <div class="services-inner">
        <div class="services-header">
          <span class="label-tag" data-i18n="about.skillsTag">What I Do</span>
          <h2 data-i18n="about.skillsTitle">My Skills</h2>
        </div>
        <div class="services-grid">
          <div class="service-card">
            <div class="service-icon"><img src="/common/game.webp" alt="Game Design" class="service-icon-img" /></div>
            <h3 data-i18n="about.skill1Title">Game Design</h3>
            <p data-i18n="about.skill1Desc">Full-cycle game design from concept to final product, including level design, game mechanics, and player experience optimization.</p>
          </div>
          <div class="service-card">
            <div class="service-icon"><img src="/common/PC.webp" alt="Web Design" class="service-icon-img" /></div>
            <h3 data-i18n="about.skill2Title">Web Design</h3>
            <p data-i18n="about.skill2Desc">Modern, responsive web design with focus on user experience, accessibility, and visual impact.</p>
          </div>
          <div class="service-card">
            <div class="service-icon"><img src="/common/MOBILE.webp" alt="Mobile Design" class="service-icon-img" /></div>
            <h3 data-i18n="about.skill3Title">Mobile Design</h3>
            <p data-i18n="about.skill3Desc">Intuitive mobile app design optimized for touch interactions and seamless user flows.</p>
          </div>
          <div class="service-card">
            <div class="service-icon"><img src="/common/DESIGN.webp" alt="UI/UX Design" class="service-icon-img" /></div>
            <h3 data-i18n="about.skill4Title">UI/UX Design</h3>
            <p data-i18n="about.skill4Desc">User-centered interface design driven by research, wireframing, prototyping, and usability testing.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- 联系方式 -->
    <section class="contact-section" id="contact">
      <div class="contact-inner">
        <div class="contact-grid">
          <div class="contact-info">
            <span class="label-tag" data-i18n="about.contactTag">Contact Me</span>
            <h2 data-i18n="about.contactTitle">Contact Me</h2>
            <p data-i18n="about.contactDesc">Want to learn more about me and my work? I'd love to hear from you.</p>
          </div>
          <div class="contact-details">
            <div class="contact-text-items">
              <div class="contact-item">
                <span class="contact-label" data-i18n="about.contactEmail">Email</span>
                <a href="mailto:{config.contact.email || '978973965@qq.com'}" class="contact-value">{config.contact.email || '978973965@qq.com'}</a>
              </div>
              <div class="contact-item">
                <span class="contact-label" data-i18n="about.contactWechat">WeChat</span>
                <span class="contact-value">{config.contact.wechat || 'XY13538160713'}</span>
              </div>
              <div class="contact-item">
                <span class="contact-label" data-i18n="about.contactLocation">Location</span>
                <span class="contact-value" data-i18n="about.contactLocationValue">Shenzhen, Guangdong, China</span>
              </div>
            </div>
            <div class="contact-qrcode-wrap">
              <img src="/common/qrcode.webp" alt="WeChat QR Code" class="qrcode-img" />
              <span class="qrcode-label" data-i18n="about.contactQrcode">Scan to add WeChat</span>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <!-- 页脚 -->
  <footer class="site-footer">
    <div class="footer-inner">
      <div class="footer-top">
        <div class="footer-brand">
          <div class="footer-logo">
            <img src="/common/logo.webp" alt="Xuyang Logo" class="footer-logo-img" />
          </div>
          <p>{config.site.description}</p>
        </div>
        <div class="footer-nav">
          <div class="footer-col">
            <h4 data-i18n="footer.navigation">Navigation</h4>
            <a href="/" data-i18n="footer.home">Home</a>
            <a href="/works" data-i18n="footer.work">Work</a>
            <a href="/about" data-i18n="footer.about">About</a>
          </div>
        </div>
      </div>
      <div class="footer-bottom">
        <p>&copy; 2026 {config.site.name}. <span data-i18n="footer.rights">All rights reserved.</span></p>
      </div>
    </div>
  </footer>
  <script is:inline src="/js/i18n.js"></script>
</body>
</html>

<style>
  /* ===== 导航栏 ===== */
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 1000;
    padding: 1.8rem var(--container-padding);
    background: rgba(8, 8, 10, 0.92);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--border);
    transition: all 0.4s var(--ease-out);
  }

  .site-header.scrolled {
    padding-top: 0.9rem;
    padding-bottom: 0.9rem;
  }

  .header-inner {
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    text-decoration: none;
    color: var(--text-primary);
    flex-shrink: 0;
  }

  .logo-img {
    height: 48px;
    width: auto;
    display: block;
    object-fit: contain;
  }

  .nav-right {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .main-nav { display: flex; gap: 2.5rem; align-items: center; }

  .nav-link {
    color: var(--text-secondary);
    text-decoration: none;
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    transition: color 0.3s ease;
    position: relative;
    padding: 0.25rem 0;
  }

  .nav-link.active, .nav-link:hover { color: var(--text-primary); }

  .nav-link::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 0;
    height: 1.5px;
    background: var(--accent);
    transition: width 0.3s var(--ease-out);
  }

  .nav-link.active::after, .nav-link:hover::after { width: 100%; }

  .lang-toggle {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    background: transparent;
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 6px;
    padding: 0.4rem 0.7rem;
    cursor: pointer;
    transition: all 0.3s ease;
    color: var(--text-secondary);
    font-family: inherit;
  }
  .lang-toggle:hover {
    border-color: var(--accent);
    color: var(--accent);
    background: rgba(45, 212, 191, 0.05);
  }
  .lang-icon { width: 18px; height: 18px; object-fit: contain; opacity: 0.85; transition: opacity 0.3s; }
  .lang-toggle:hover .lang-icon { opacity: 1; }
  .lang-label { font-size: 0.72rem; font-weight: 600; letter-spacing: 0.05em; text-transform: uppercase; }

  .nav-cta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: #08080a;
    text-decoration: none;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    padding: 0.6rem 1.4rem;
    background: var(--accent);
    border: 1px solid var(--accent);
    border-radius: 0;
    transition: all 0.3s ease;
  }

  .nav-cta:hover {
    background: #3dd4c6;
    border-color: #3dd4c6;
  }

  /* ===== About Hero ===== */
  .about-hero {
    padding: 10rem var(--container-padding) 5rem;
    background: var(--bg-primary);
    text-align: center;
  }

  .hero-content {
    max-width: 750px;
    margin: 0 auto;
  }

  .hero-badge {
    display: inline-block;
    padding: 0.35rem 1rem;
    background: rgba(78, 234, 219, 0.12);
    border: 1px solid rgba(78, 234, 219, 0.25);
    border-radius: 0;
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--accent-secondary);
    margin-bottom: 2rem;
  }

  .about-hero h1 {
    font-size: clamp(2.5rem, 5vw, 3.8rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    line-height: 1.15;
    margin-bottom: 1.5rem;
    color: var(--text-primary);
  }

  .hero-desc {
    font-size: 1.1rem;
    color: var(--text-secondary);
    line-height: 1.7;
  }

  /* ===== About Section ===== */
  .about-section {
    padding: var(--section-padding) var(--container-padding);
    background: var(--bg-primary);
    border-top: 1px solid var(--border);
  }

  .about-inner {
    max-width: var(--container-max);
    margin: 0 auto;
  }

  .about-grid {
    display: grid;
    grid-template-columns: 250px 1fr;
    gap: 4rem;
  }

  .about-label {
    position: sticky;
    top: 6rem;
  }

  .label-tag {
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .about-text-large {
    font-size: 1rem;
    color: var(--text-secondary);
    line-height: 1.8;
    margin-bottom: 1.5rem;
    font-weight: 400;
  }

  .about-text {
    font-size: 1rem;
    color: var(--text-secondary);
    line-height: 1.8;
  }

  /* ===== 数据亮点 ===== */
  .highlights-section {
    padding: var(--section-padding) var(--container-padding);
    background: var(--bg-secondary);
  }

  .highlights-inner {
    max-width: var(--container-max);
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
  }

  .highlight-card {
    padding: 2.5rem 2rem;
    background: var(--bg-tertiary);
    border: 1px solid var(--border);
    border-radius: 16px;
    text-align: center;
    transition: border-color 0.3s ease;
  }

  .highlight-card:hover {
    border-color: var(--border-hover);
  }

  .highlight-number {
    display: block;
    font-size: 2.8rem;
    font-weight: 800;
    color: var(--text-primary);
    letter-spacing: -0.02em;
    margin-bottom: 0.75rem;
    line-height: 1;
  }

  .highlight-label {
    font-size: 0.75rem;
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    line-height: 1.5;
  }

  /* ===== 服务 ===== */
  .services-section {
    padding: var(--section-padding) var(--container-padding);
    background: var(--bg-primary);
  }

  .services-inner {
    max-width: var(--container-max);
    margin: 0 auto;
  }

  .services-header {
    margin-bottom: 3.5rem;
  }

  .services-header h2 {
    margin-top: 0.75rem;
    font-size: clamp(1.8rem, 3vw, 2.5rem);
    color: var(--text-primary);
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
  }

  .service-card {
    padding: 2.5rem 2rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 16px;
    transition: all 0.3s ease;
    text-align: center;
  }

  .service-card:hover {
    border-color: var(--border-hover);
    transform: translateY(-4px);
    box-shadow: 0 12px 40px -10px rgba(0, 0, 0, 0.4);
  }

  .service-icon {
    width: 86px;
    height: 86px;
    margin: 0 auto 1.25rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .service-icon-img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    filter: grayscale(40%) brightness(0.85);
    opacity: 0.75;
  }

  .service-card h3 {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 0.75rem;
  }

  .service-card p {
    font-size: 0.88rem;
    color: var(--text-secondary);
    line-height: 1.7;
  }

  /* ===== 联系 ===== */
  .contact-section {
    padding: var(--section-padding) var(--container-padding);
    background: var(--bg-secondary);
  }

  .contact-inner {
    max-width: var(--container-max);
    margin: 0 auto;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    align-items: flex-start;
  }

  .contact-info h2 {
    font-size: clamp(2rem, 4vw, 2.8rem);
    font-weight: 700;
    margin-top: 0.5rem;
    margin-bottom: 0.6rem;
    line-height: 1.1;
    color: var(--text-primary);
  }

  .contact-info p {
    font-size: 1rem;
    color: var(--text-secondary);
    line-height: 1.4;
  }

  .contact-details {
    display: flex;
    flex-direction: row;
    align-items: flex-start;
    gap: 3rem;
    padding-top: 1.5rem;
  }

  /* 左侧：Email/WeChat/Location 纵向排列 */
  .contact-text-items {
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
    flex: 1;
  }

  .contact-item {
    padding-bottom: 0.8rem;
    border-bottom: 1px solid var(--border);
  }

  .contact-item:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .contact-label {
    display: block;
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-tertiary);
    margin-bottom: 0.4rem;
  }

  .contact-value {
    font-size: 1.05rem;
    color: var(--text-primary);
    font-weight: 500;
    text-decoration: none;
    transition: color 0.2s;
  }

  a.contact-value:hover {
    color: var(--accent);
  }

  /* 右侧：微信二维码 */
  .contact-qrcode-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    flex: 0 0 auto;
  }

  .qrcode-img {
    width: 140px;
    height: 140px;
    object-fit: cover;
    border-radius: 10px;
    border: 1px solid var(--border);
  }

  .qrcode-label {
    font-size: 0.65rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    color: var(--text-tertiary);
    white-space: nowrap;
  }

  /* ===== 页脚 ===== */
  .site-footer {
    padding: 4rem var(--container-padding) 2rem;
    background: var(--bg-primary);
    border-top: 1px solid var(--border);
  }

  .footer-inner { width: 100%; }

  .footer-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    padding-bottom: 3rem;
    border-bottom: 1px solid var(--border);
    margin-bottom: 2rem;
  }

  .footer-logo {
    display: flex;
    align-items: center;
    margin-bottom: 0.75rem;
  }

  .footer-logo-img {
    height: 48px;
    width: auto;
    object-fit: contain;
  }

  .footer-brand p { color: var(--text-tertiary); font-size: 0.9rem; max-width: 280px; }
  .footer-nav { display: flex; gap: 5rem; }

  .footer-col h4 {
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-secondary);
    margin-bottom: 1rem;
  }

  .footer-col a {
    display: block;
    color: var(--text-tertiary);
    text-decoration: none;
    font-size: 0.9rem;
    padding: 0.3rem 0;
    transition: color 0.2s;
  }

  .footer-col a:hover { color: var(--text-primary); }
  .footer-bottom p { color: var(--text-tertiary); font-size: 0.8rem; }

  /* ===== 响应式 ===== */
  @media (max-width: 1024px) {
    .about-grid { grid-template-columns: 1fr; gap: 1.5rem; }
    .about-label { position: static; }
    .highlights-inner { grid-template-columns: repeat(2, 1fr); }
    .services-grid { grid-template-columns: repeat(2, 1fr); }
    .contact-grid { gap: 2rem; }
  }

  /* ===== 汉堡菜单按钮 ===== */
  .hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 32px;
    height: 32px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    z-index: 1001;
  }

  .hamburger-line {
    display: block;
    width: 100%;
    height: 2px;
    background: var(--text-primary);
    border-radius: 2px;
    transition: all 0.3s ease;
    transform-origin: center;
  }

  .hamburger.active .hamburger-line:nth-child(1) {
    transform: rotate(45deg) translate(5px, 5px);
  }

  .hamburger.active .hamburger-line:nth-child(2) {
    opacity: 0;
  }

  .hamburger.active .hamburger-line:nth-child(3) {
    transform: rotate(-45deg) translate(5px, -5px);
  }

  @media (max-width: 768px) {
    .site-header { padding: 1rem 1.5rem; }
    .site-header.scrolled { padding-top: 0.7rem; padding-bottom: 0.7rem; }
    .logo-img { height: 40px; }
    .nav-right { gap: 0.8rem; }
    .nav-cta { display: none; }
    .lang-toggle { order: 0; }
    .hamburger { display: flex; }

    .main-nav {
      position: fixed;
      top: 0;
      right: -100%;
      width: 70%;
      max-width: 300px;
      height: 100vh;
      background: rgba(40, 42, 54, 0.92);
      backdrop-filter: blur(24px);
      -webkit-backdrop-filter: blur(24px);
      flex-direction: column;
      align-items: flex-start;
      justify-content: flex-start;
